## MICROFINA local environment
## Copy to ".env" (do not commit .env) then run: docker compose up -d
##
MSSQL_SA_PASSWORD=Password123!

## Backend Spring Boot (lues depuis .env à la racine au démarrage)
## Port 1434 = mapping hôte du conteneur SQL dans docker-compose.yaml
MICROFINA_DB_URL=jdbc:sqlserver://localhost:1434;databaseName=microfina;encrypt=true;trustServerCertificate=true
MICROFINA_DB_USERNAME=sa
MICROFINA_DB_PASSWORD=Password123!
