<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P5-003 – Table cloture_journaliere (Journal Day-Close)

        Trace chaque fermeture de journée comptable.
        Une ligne par (date, agence) ; la contrainte UQ garantit
        qu'on ne peut pas clôturer deux fois la même journée sur
        la même agence.

        Workflow ClotureService :
          1. Vérifier que tous les Reglements de la journée ont un
             idcomptabilite valide (NOT NULL + enregistrement existant).
          2. Vérifier qu'aucune Reglement EN_ATTENTE n'existe pour la date.
          3. Insérer la ligne cloture_journaliere (STATUT = 'CLOTURE').
          4. Toute violation lève une ClotureException (rollback transaction).

        Colonnes de synthèse (NB_REGLEMENTS, MONTANT_TOTAL) :
          Alimentées par ClotureService lors de la clôture.
          Permettent de valider a posteriori les totaux journaliers.

        STATUT lifecycle :
          CLOTURE   – journée fermée normalement
          ANNULE    – réouverture exceptionnelle (opération superviseur)
          REOUVERT  – journée temporairement rouverte pour correction
    -->

    <!-- ═══════════════════════════════════════════════════════
         Table principale
         ═══════════════════════════════════════════════════════ -->
    <changeSet id="P5-003-create-table-cloture_journaliere" author="microfina">

        <createTable tableName="cloture_journaliere">

            <!-- PK -->
            <column name="IDCLOTURE" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"
                             primaryKeyName="PK_cloture_journaliere"/>
            </column>

            <!-- Clé métier : date de la journée clôturée -->
            <column name="DATE_CLOTURE" type="DATE">
                <constraints nullable="false"/>
            </column>

            <!-- Horodatage précis de la clôture (serveur) -->
            <column name="DATE_HEURE_CLOTURE" type="DATETIME">
                <constraints nullable="false"/>
            </column>

            <!-- Agent ayant déclenché la clôture -->
            <column name="UTILISATEUR" type="NVARCHAR(48)">
                <constraints nullable="false"/>
            </column>

            <!-- Statut de la journée -->
            <column name="STATUT" type="NVARCHAR(20)" defaultValue="CLOTURE">
                <constraints nullable="false"/>
            </column>

            <!-- Agence concernée (NULL = clôture centrale multi-agences) -->
            <column name="CODE_AGENCE" type="NVARCHAR(25)">
                <constraints nullable="true"/>
            </column>

            <!-- Synthèse comptable de la journée -->
            <column name="NB_REGLEMENTS" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_TOTAL" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- Détail des flux (inclut TAXE pour conformité P4-013) -->
            <column name="MONTANT_CAPITAL" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_INTERET" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_PENALITE" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_ASSURANCE" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_COMMISSION" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_TAXE" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- Motif de réouverture ou note d'annulation -->
            <column name="OBSERVATIONS" type="NVARCHAR(500)">
                <constraints nullable="true"/>
            </column>

            <!-- Optimistic lock -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <rollback>
            <dropTable tableName="cloture_journaliere"/>
        </rollback>

    </changeSet>

    <!-- ═══════════════════════════════════════════════════════
         Contrainte d'unicité : une seule clôture par (date, agence)
         NULL sur CODE_AGENCE (clôture centrale) reste permis.
         ═══════════════════════════════════════════════════════ -->
    <changeSet id="P5-003-uq-cloture-date-agence" author="microfina">

        <addUniqueConstraint
            tableName      = "cloture_journaliere"
            columnNames    = "DATE_CLOTURE, CODE_AGENCE"
            constraintName = "UQ_cloture_journaliere_date_agence"/>

        <rollback>
            <dropUniqueConstraint tableName="cloture_journaliere"
                                  constraintName="UQ_cloture_journaliere_date_agence"/>
        </rollback>

    </changeSet>

    <!-- ═══════════════════════════════════════════════════════
         Index de recherche par date (requêtes journalières fréquentes)
         ═══════════════════════════════════════════════════════ -->
    <changeSet id="P5-003-idx-cloture-date" author="microfina">

        <createIndex indexName="IDX_cloture_journaliere_DATE_CLOTURE"
                     tableName="cloture_journaliere">
            <column name="DATE_CLOTURE"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="IDX_cloture_journaliere_DATE_CLOTURE"
                       tableName="cloture_journaliere"/>
        </rollback>

    </changeSet>

    <!-- ═══════════════════════════════════════════════════════
         FK vers AGENCE (nullable – clôture centrale sans agence)
         ═══════════════════════════════════════════════════════ -->
    <changeSet id="P5-003-fk-cloture-agence" author="microfina">

        <addForeignKeyConstraint
            baseTableName          = "cloture_journaliere"
            baseColumnNames        = "CODE_AGENCE"
            referencedTableName    = "AGENCE"
            referencedColumnNames  = "CODE_AGENCE"
            constraintName         = "FK_cloture_journaliere_AGENCE"
            onDelete               = "SET NULL"
            onUpdate               = "CASCADE"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName  = "cloture_journaliere"
                                      constraintName = "FK_cloture_journaliere_AGENCE"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
