<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P10-001c – Garantie
        Entité générique de garantie/sûreté associée à un crédit.
        Complète les tables spécifiques Phase 4 (HYPOTHEQUE_CREDIT, gageCredit,
        Caution, Nantissement) en fournissant un point d'entrée unifié permettant
        d'enregistrer n'importe quel type de garantie sans multiplier les jointures.

        FK dépendances :
          Credits       (IDCREDIT)          – P4-001
          type_garantie (CODE_TYPE_GARANTIE) – P10-001
          membres       (NUM_MEMBRE)         – Phase 2 (garant optionnel)

        Colonnes clés :
          VALEUR_ESTIMEE : valeur marchande estimée au moment de l'évaluation
          TAUX_COUVERTURE : % de couverture du capital = VALEUR_ESTIMEE / MONTANT_CREDIT * 100
          DATE_EVALUATION : date de l'évaluation (expertise)
          OBSERVATIONS    : tout détail complémentaire (adresse bien, matricule véhicule, etc.)
          STATUT          : ACTIF / LIBERE / SAISI / EXPIRE
    -->

    <!-- ─── 1. Création de la table ─── -->
    <changeSet id="P10-001c-create-Garantie" author="microfina">
        <comment>Table générique de garantie/sûreté crédit — unifie les types existants et futurs</comment>

        <createTable tableName="Garantie">

            <column name="IDGARANTIE" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_Garantie"
                             nullable="false"/>
            </column>

            <!-- Type de garantie (FK vers type_garantie.CODE) -->
            <column name="CODE_TYPE_GARANTIE" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <!-- Crédit garanti (FK vers Credits.IDCREDIT) -->
            <column name="IDCREDIT" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <!-- Membre garant (optionnel) -->
            <column name="NUM_MEMBRE_GARANT" type="NVARCHAR(25)"/>

            <!-- ── Valorisation ─────────────────────────────── -->

            <!-- Valeur de marché estimée au moment de l'évaluation -->
            <column name="VALEUR_ESTIMEE" type="DECIMAL(19,4)">
                <constraints nullable="false"/>
            </column>

            <!-- Taux de couverture calculé = VALEUR_ESTIMEE / MONTANT_CREDIT × 100 -->
            <column name="TAUX_COUVERTURE" type="DECIMAL(10,4)"/>

            <!-- Date de l'expertise / évaluation -->
            <column name="DATE_EVALUATION" type="DATE"/>

            <!-- ── Suivi de vie de la garantie ──────────────── -->

            <!-- ACTIF | LIBERE | SAISI | EXPIRE -->
            <column name="STATUT" type="NVARCHAR(20)" defaultValue="ACTIF">
                <constraints nullable="false"/>
            </column>

            <!-- Date à laquelle la garantie a été libérée ou est expirée -->
            <column name="DATE_MAINLEVEE" type="DATE"/>

            <!-- Référence documentaire (acte notarié, contrat assurance, etc.) -->
            <column name="REFERENCE_DOCUMENT" type="NVARCHAR(100)"/>

            <!-- Observations libres (adresse bien immobilier, immatriculation véhicule...) -->
            <column name="OBSERVATIONS" type="NVARCHAR(1000)"/>

            <!-- Traçabilité -->
            <column name="UTILISATEUR" type="NVARCHAR(100)"/>
            <column name="DATE_SAISIE"  type="DATE"/>

            <!-- Verrou optimiste -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- Index de recherche par crédit (cas d'usage principal) -->
        <createIndex tableName="Garantie" indexName="IDX_Garantie_idcredit">
            <column name="IDCREDIT"/>
        </createIndex>

        <!-- Index de recherche par type (pour reporting) -->
        <createIndex tableName="Garantie" indexName="IDX_Garantie_type">
            <column name="CODE_TYPE_GARANTIE"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="Garantie" indexName="IDX_Garantie_type"/>
            <dropIndex tableName="Garantie" indexName="IDX_Garantie_idcredit"/>
            <dropTable tableName="Garantie"/>
        </rollback>

    </changeSet>

    <!-- ─── 2. Clés étrangères ─── -->
    <changeSet id="P10-001c-fk-Garantie" author="microfina">
        <comment>FK Garantie → type_garantie, Credits, membres</comment>

        <addForeignKeyConstraint
            constraintName        ="FK_Garantie_type_garantie"
            baseTableName         ="Garantie"
            baseColumnNames       ="CODE_TYPE_GARANTIE"
            referencedTableName   ="type_garantie"
            referencedColumnNames ="CODE"
            onDelete              ="RESTRICT"
            onUpdate              ="CASCADE"/>

        <addForeignKeyConstraint
            constraintName        ="FK_Garantie_Credits"
            baseTableName         ="Garantie"
            baseColumnNames       ="IDCREDIT"
            referencedTableName   ="Credits"
            referencedColumnNames ="IDCREDIT"
            onDelete              ="CASCADE"
            onUpdate              ="NO ACTION"/>

        <addForeignKeyConstraint
            constraintName        ="FK_Garantie_membres"
            baseTableName         ="Garantie"
            baseColumnNames       ="NUM_MEMBRE_GARANT"
            referencedTableName   ="membres"
            referencedColumnNames ="NUM_MEMBRE"
            onDelete              ="SET NULL"
            onUpdate              ="NO ACTION"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="Garantie" constraintName="FK_Garantie_membres"/>
            <dropForeignKeyConstraint baseTableName="Garantie" constraintName="FK_Garantie_Credits"/>
            <dropForeignKeyConstraint baseTableName="Garantie" constraintName="FK_Garantie_type_garantie"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
