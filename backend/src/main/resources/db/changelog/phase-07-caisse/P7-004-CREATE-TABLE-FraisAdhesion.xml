<?xml version="1.0" encoding="UTF-8"?>
<!--
    P7-004 — Création de la table FraisAdhesion (sous-type JOINED de OperationCaisse)
    Dépendances :
      - OperationCaisse     (P7-001) → FK_FraisAdhesion_OperationCaisse   (PK partagée)
      - ValeurFraisMembre   (Phase 2) → FK_FraisAdhesion_ValeurFraisMembre (NULLABLE)
    La colonne id est à la fois PK et FK vers OperationCaisse (héritage JOINED).
    La colonne num_compte dans OperationCaisse est NULLABLE car les frais d'adhésion
    peuvent ne pas être rattachés à un compte épargne existant.
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P7-004-create-FraisAdhesion" author="microfina">
        <createTable tableName="FraisAdhesion">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="PK_FraisAdhesion" nullable="false"/>
            </column>
            <column name="id_valeur_frais_membre" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="FK_FraisAdhesion_OperationCaisse"
            baseTableName="FraisAdhesion"
            baseColumnNames="id"
            referencedTableName="OperationCaisse"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="FK_FraisAdhesion_ValeurFraisMembre"
            baseTableName="FraisAdhesion"
            baseColumnNames="id_valeur_frais_membre"
            referencedTableName="ValeurFraisMembre"
            referencedColumnNames="IDVALEURFRAISMEMBRE"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="FraisAdhesion"/>
            <dropTable tableName="FraisAdhesion"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
