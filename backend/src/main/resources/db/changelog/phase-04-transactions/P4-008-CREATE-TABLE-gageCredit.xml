<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P4-008 – gageCredit
        Movable-asset pledge (gage) securing a credit.
        Covers physical assets: vehicles, equipment, livestock, inventory, etc.
        FK dependencies: Credits (IDCREDIT) – P4-001
        DDL source of truth: Phase 4 spec – Section 11.
    -->
    <changeSet id="P4-008-create-gageCredit" author="microfina">

        <createTable tableName="gageCredit">

            <column name="IDGAGE" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_gageCredit"
                             nullable="false"/>
            </column>

            <column name="DESCRIPTION"   type="NVARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <!-- Estimated value of the pledged asset -->
            <column name="VALEUR"        type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- VEHICULE | MATERIEL | BETAIL | STOCK | AUTRE -->
            <column name="TYPE_GAGE"     type="NVARCHAR(100)">
                <constraints nullable="true"/>
            </column>

            <!-- Asset serial / registration number -->
            <column name="NUMERO_SERIE"  type="NVARCHAR(100)">
                <constraints nullable="true"/>
            </column>

            <!-- Date pledge deed was signed -->
            <column name="DATE_GAGE"     type="DATE">
                <constraints nullable="true"/>
            </column>

            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <rollback>
            <dropTable tableName="gageCredit"/>
        </rollback>

    </changeSet>

    <changeSet id="P4-008-fk-gageCredit-Credits" author="microfina">

        <addColumn tableName="gageCredit">
            <column name="idcredit" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint
            constraintName        = "FK_gageCredit_Credits"
            baseTableName         = "gageCredit"
            baseColumnNames       = "idcredit"
            referencedTableName   = "Credits"
            referencedColumnNames = "IDCREDIT"
            onDelete              = "CASCADE"
            onUpdate="NO ACTION"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="gageCredit"
                                      constraintName="FK_gageCredit_Credits"/>
            <dropColumn tableName="gageCredit" columnName="idcredit"/>
        </rollback>

    </changeSet>

</databaseChangeLog>