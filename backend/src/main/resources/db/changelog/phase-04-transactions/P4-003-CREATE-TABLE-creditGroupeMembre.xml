<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P4-003 – creditGroupeMembre
        Per-member individual credit breakdown for a group loan.
        Each row represents one member's share in a Creditsgroupe.
        Unique constraint: one row per (idcreditgroupe, nummembre).

        FK dependencies:
          Creditsgroupe / Credits (IDCREDIT) – P4-002
          membres (NUM_MEMBRE)               – Phase 2
        DDL source of truth: Phase 4 spec – Section 8.
    -->
    <changeSet id="P4-003-create-creditGroupeMembre" author="microfina">

        <createTable tableName="creditGroupeMembre">

            <!-- PK -->
            <column name="IDCREDITGROUPEMEMBRE" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_creditGroupeMembre"
                             nullable="false"/>
            </column>

            <!-- Member's individual loan amount within the group -->
            <column name="MONTANT_INDIVIDUEL" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- Member's proportional share of the group total (0–1) -->
            <column name="PART" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- Per-member outstanding capital balance -->
            <column name="SOLDE_CAPITAL" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- Per-member lifecycle status (mirrors CreditStatut) -->
            <column name="STATUT" type="NVARCHAR(20)" defaultValue="DRAFT">
                <constraints nullable="true"/>
            </column>

            <!-- Optimistic lock -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <rollback>
            <dropTable tableName="creditGroupeMembre"/>
        </rollback>

    </changeSet>

    <!-- Unique: one record per (group credit, member) -->
    <changeSet id="P4-003-uq-fk-creditGroupeMembre" author="microfina">

        <addColumn tableName="creditGroupeMembre">
            <column name="idcreditgroupe" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="creditGroupeMembre">
            <column name="nummembre" type="NVARCHAR(25)">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addUniqueConstraint
            tableName      = "creditGroupeMembre"
            columnNames    = "idcreditgroupe, nummembre"
            constraintName = "UQ_creditGroupeMembre_credit_membre"/>

        <addForeignKeyConstraint
            constraintName        = "FK_creditGroupeMembre_Credits"
            baseTableName         = "creditGroupeMembre"
            baseColumnNames       = "idcreditgroupe"
            referencedTableName   = "Credits"
            referencedColumnNames = "IDCREDIT"
            onDelete              = "CASCADE"
            onUpdate="NO ACTION"/>

        <addForeignKeyConstraint
            constraintName        = "FK_creditGroupeMembre_membres"
            baseTableName         = "creditGroupeMembre"
            baseColumnNames       = "nummembre"
            referencedTableName   = "membres"
            referencedColumnNames = "NUM_MEMBRE"
            onDelete                 = "NO ACTION"
            onUpdate="NO ACTION"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="creditGroupeMembre"
                                      constraintName="FK_creditGroupeMembre_membres"/>
            <dropForeignKeyConstraint baseTableName="creditGroupeMembre"
                                      constraintName="FK_creditGroupeMembre_Credits"/>
            <dropUniqueConstraint tableName="creditGroupeMembre"
                                  constraintName="UQ_creditGroupeMembre_credit_membre"/>
            <dropColumn tableName="creditGroupeMembre" columnName="nummembre"/>
            <dropColumn tableName="creditGroupeMembre" columnName="idcreditgroupe"/>
        </rollback>

    </changeSet>

</databaseChangeLog>