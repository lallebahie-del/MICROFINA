<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P4-011 – Reglement
        Header record for a credit repayment transaction.
        One Reglement may settle one or more Amortp instalments (via detail_reglement).
        Also triggers Comptabilite entries for the disbursement event.

        FK dependencies:
          Credits (IDCREDIT)   – P4-001
          AGENCE  (CODE_AGENCE) – Phase 1
        DDL source of truth: Phase 4 spec – Section 10.
    -->
    <changeSet id="P4-011-create-Reglement" author="microfina">

        <createTable tableName="Reglement">

            <!-- PK -->
            <column name="IDREGLEMENT" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_Reglement"
                             nullable="false"/>
            </column>

            <!-- ── Transaction reference ────────────────────────────── -->
            <column name="NUMPIECE"           type="NVARCHAR(50)">
                <constraints nullable="true"/>
            </column>

            <column name="DATE_REGLEMENT"     type="DATE">
                <constraints nullable="false"/>
            </column>

            <!-- ── Breakdown of total received ──────────────────────── -->
            <column name="MONTANT_TOTAL"      type="DECIMAL(19,4)">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_CAPITAL"    type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_INTERET"    type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_PENALITE"   type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_ASSURANCE"  type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="MONTANT_COMMISSION" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- ── Payment mode ──────────────────────────────────────── -->
            <!-- ESPECES | VIREMENT | CHEQUE | MOBILE_MONEY | PRELEVEMENT -->
            <column name="MODE_PAIEMENT"      type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Status ────────────────────────────────────────────── -->
            <!-- VALIDE | ANNULE | EN_ATTENTE -->
            <column name="STATUT"             type="NVARCHAR(20)" defaultValue="VALIDE">
                <constraints nullable="false"/>
            </column>

            <!-- ── Comptabilite linkage ──────────────────────────────── -->
            <!-- ID of the journal entry created for this repayment -->
            <column name="idcomptabilite"     type="BIGINT">
                <constraints nullable="true"/>
            </column>

            <!-- ── Audit ─────────────────────────────────────────────── -->
            <column name="utilisateur"        type="NVARCHAR(48)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Optimistic lock ───────────────────────────────────── -->
            <column name="VERSION"            type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <rollback>
            <dropTable tableName="Reglement"/>
        </rollback>

    </changeSet>

    <!-- FK → Credits -->
    <changeSet id="P4-011-fk-Reglement-Credits" author="microfina">

        <addColumn tableName="Reglement">
            <column name="idcredit" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <createIndex tableName="Reglement" indexName="IDX_Reglement_idcredit">
            <column name="idcredit"/>
        </createIndex>

        <addForeignKeyConstraint
            constraintName        = "FK_Reglement_Credits"
            baseTableName         = "Reglement"
            baseColumnNames       = "idcredit"
            referencedTableName   = "Credits"
            referencedColumnNames = "IDCREDIT"
            onDelete                 = "NO ACTION"
            onUpdate="NO ACTION"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="Reglement"
                                      constraintName="FK_Reglement_Credits"/>
            <dropIndex tableName="Reglement" indexName="IDX_Reglement_idcredit"/>
            <dropColumn tableName="Reglement" columnName="idcredit"/>
        </rollback>

    </changeSet>

    <!-- FK → AGENCE -->
    <changeSet id="P4-011-fk-Reglement-agence" author="microfina">

        <addColumn tableName="Reglement">
            <column name="agence" type="NVARCHAR(25)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint
            constraintName        = "FK_Reglement_AGENCE"
            baseTableName         = "Reglement"
            baseColumnNames       = "agence"
            referencedTableName   = "AGENCE"
            referencedColumnNames = "CODE_AGENCE"
            onDelete              = "SET NULL"
            onUpdate="NO ACTION"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="Reglement"
                                      constraintName="FK_Reglement_AGENCE"/>
            <dropColumn tableName="Reglement" columnName="agence"/>
        </rollback>

    </changeSet>

    <!-- FK → comptabilite (journal entry created at repayment) -->
    <changeSet id="P4-011-fk-Reglement-comptabilite" author="microfina">

        <addForeignKeyConstraint
            constraintName        = "FK_Reglement_comptabilite"
            baseTableName         = "Reglement"
            baseColumnNames       = "idcomptabilite"
            referencedTableName   = "comptabilite"
            referencedColumnNames = "IDCOMPTABILITE"
            onDelete              = "SET NULL"
            onUpdate="NO ACTION"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="Reglement"
                                      constraintName="FK_Reglement_comptabilite"/>
        </rollback>

    </changeSet>

</databaseChangeLog>