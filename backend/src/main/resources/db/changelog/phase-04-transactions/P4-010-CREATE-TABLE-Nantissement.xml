<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P4-010 – Nantissement
        Lien over intangible / financial assets (fonds de commerce, créances,
        stocks, titres). Distinct from Gage (physical) and Hypothèque (real estate).
        FK dependencies: Credits (IDCREDIT) – P4-001
        DDL source of truth: Phase 4 spec – Section 11.
    -->
    <changeSet id="P4-010-create-Nantissement" author="microfina">

        <createTable tableName="Nantissement">

            <column name="IDNANTISSEMENT" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_Nantissement"
                             nullable="false"/>
            </column>

            <column name="DESCRIPTION"       type="NVARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <!-- Estimated value of the lien'd asset -->
            <column name="VALEUR"            type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- FONDS_COMMERCE | CREANCE | TITRES | STOCK | AUTRE -->
            <column name="TYPE_NANTISSEMENT" type="NVARCHAR(100)">
                <constraints nullable="true"/>
            </column>

            <!-- Official registration reference (RCCM, notarial deed, etc.) -->
            <column name="REFERENCE_ACTE"    type="NVARCHAR(100)">
                <constraints nullable="true"/>
            </column>

            <!-- Date the nantissement deed was signed -->
            <column name="DATE_NANTISSEMENT" type="DATE">
                <constraints nullable="true"/>
            </column>

            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <rollback>
            <dropTable tableName="Nantissement"/>
        </rollback>

    </changeSet>

    <changeSet id="P4-010-fk-Nantissement-Credits" author="microfina">

        <addColumn tableName="Nantissement">
            <column name="idcredit" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint
            constraintName        = "FK_Nantissement_Credits"
            baseTableName         = "Nantissement"
            baseColumnNames       = "idcredit"
            referencedTableName   = "Credits"
            referencedColumnNames = "IDCREDIT"
            onDelete              = "CASCADE"
            onUpdate="NO ACTION"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="Nantissement"
                                      constraintName="FK_Nantissement_Credits"/>
            <dropColumn tableName="Nantissement" columnName="idcredit"/>
        </rollback>

    </changeSet>

</databaseChangeLog>