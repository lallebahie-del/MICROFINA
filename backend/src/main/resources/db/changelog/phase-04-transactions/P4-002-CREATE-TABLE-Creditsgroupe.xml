<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P4-002 – Creditsgroupe
        JOINED inheritance subtype of Credits for group/solidarity loans.
        PK = IDCREDIT which is also the FK back to Credits.
        Adds group-specific columns only; all base credit fields live in Credits.

        FK dependencies:
          Credits (IDCREDIT) – P4-001
        DDL source of truth: Phase 4 spec – Section 8.
    -->
    <changeSet id="P4-002-create-Creditsgroupe" author="microfina">

        <createTable tableName="Creditsgroupe">

            <!-- PK = FK to Credits (JOINED inheritance) -->
            <column name="IDCREDIT" type="BIGINT">
                <constraints primaryKey="true"
                             primaryKeyName="PK_Creditsgroupe"
                             nullable="false"/>
            </column>

            <!-- Total number of group members sharing this credit -->
            <column name="NOMBRE_MEMBRES" type="INT">
                <constraints nullable="true"/>
            </column>

            <!-- Individual share per member (MONTANT_ACCORDE / NOMBRE_MEMBRES by default) -->
            <column name="MONTANT_PAR_MEMBRE" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- Solidarity type: SOLIDAIRE (joint liability) | CONJOINT (joint application) -->
            <column name="TYPE_GROUPE" type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <!-- Optimistic lock -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- JOINED inheritance FK -->
        <addForeignKeyConstraint
            constraintName        = "FK_Creditsgroupe_Credits"
            baseTableName         = "Creditsgroupe"
            baseColumnNames       = "IDCREDIT"
            referencedTableName   = "Credits"
            referencedColumnNames = "IDCREDIT"
            onDelete              = "CASCADE"
            onUpdate="NO ACTION"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="Creditsgroupe"
                                      constraintName="FK_Creditsgroupe_Credits"/>
            <dropTable tableName="Creditsgroupe"/>
        </rollback>

    </changeSet>

</databaseChangeLog>