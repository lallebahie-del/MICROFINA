<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P13-003-alter-utilisateur-profile-adresse" author="microfina-phase13">
        <comment>Adresse et compte courant sur le profil utilisateur mobile</comment>

        <addColumn tableName="Utilisateur">
            <column name="adresse" type="NVARCHAR(500)"/>
            <column name="ville" type="NVARCHAR(255)"/>
            <column name="latitude" type="NVARCHAR(50)"/>
            <column name="longitude" type="NVARCHAR(50)"/>
            <column name="num_compte_courant" type="NVARCHAR(255)"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="Utilisateur" columnName="adresse"/>
            <dropColumn tableName="Utilisateur" columnName="ville"/>
            <dropColumn tableName="Utilisateur" columnName="latitude"/>
            <dropColumn tableName="Utilisateur" columnName="longitude"/>
            <dropColumn tableName="Utilisateur" columnName="num_compte_courant"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
