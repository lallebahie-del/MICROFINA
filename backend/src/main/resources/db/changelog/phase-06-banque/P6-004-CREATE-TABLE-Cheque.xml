<?xml version="1.0" encoding="UTF-8"?>
<!--
    P6-004 — Création de la table Cheque
    Dépendances :
      - CarnetCheque  (P6-003) → FK_Cheque_CarnetCheque
    Référencée par : RemiseCheque (via FK_RemiseCheque_Cheque)
    Statuts valides : EMIS / ENCAISSE / REJETE / OPPOSE
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P6-004-create-Cheque" author="microfina">
        <createTable tableName="Cheque">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_Cheque" nullable="false"/>
            </column>
            <column name="numero" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="montant" type="DECIMAL(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="beneficiaire" type="NVARCHAR(255)"/>
            <column name="date_emission" type="DATE"/>
            <column name="date_encaissement" type="DATE"/>
            <column name="statut" type="NVARCHAR(20)" defaultValue="EMIS">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="carnet_cheque_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="FK_Cheque_CarnetCheque"
            baseTableName="Cheque"
            baseColumnNames="carnet_cheque_id"
            referencedTableName="CarnetCheque"
            referencedColumnNames="id"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="Cheque"/>
            <dropTable tableName="Cheque"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
