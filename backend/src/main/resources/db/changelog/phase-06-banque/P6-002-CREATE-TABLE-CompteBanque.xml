<?xml version="1.0" encoding="UTF-8"?>
<!--
    P6-002 — Création de la table CompteBanque
    Dépendances :
      - Banque           (P6-001) → FK_CompteBanque_Banque
      - AGENCE           (Phase 1) → FK_CompteBanque_Agence
    Référencée par : CarnetCheque, OperationBanque, Virement (source & destination)
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P6-002-create-CompteBanque" author="microfina">
        <createTable tableName="CompteBanque">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_CompteBanque" nullable="false"/>
            </column>
            <column name="numero_compte" type="NVARCHAR(34)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UQ_CompteBanque_NumeroCompte"/>
            </column>
            <column name="libelle" type="NVARCHAR(255)"/>
            <column name="devise" type="NVARCHAR(10)" defaultValue="MRU">
                <constraints nullable="false"/>
            </column>
            <column name="solde" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="actif" type="BIT" defaultValueNumeric="1"/>
            <column name="version" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="code_banque" type="NVARCHAR(20)"/>
            <column name="code_agence" type="NVARCHAR(25)"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="FK_CompteBanque_Banque"
            baseTableName="CompteBanque"
            baseColumnNames="code_banque"
            referencedTableName="Banque"
            referencedColumnNames="code_banque"/>

        <addForeignKeyConstraint
            constraintName="FK_CompteBanque_Agence"
            baseTableName="CompteBanque"
            baseColumnNames="code_agence"
            referencedTableName="AGENCE"
            referencedColumnNames="CODE_AGENCE"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="CompteBanque"/>
            <dropTable tableName="CompteBanque"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
