<?xml version="1.0" encoding="UTF-8"?>
<!--
    P8-002 — Création de la table LigneBudget (détail d'un Budget)
    Dépendances :
      - Budget  (Phase 8, P8-001) → FK_LigneBudget_Budget   (budget_id) NOT NULL
    Référencée par : MouvementBudget (Phase 8, P8-003)
    Types de ligne : RECETTE / DEPENSE
    Note : La colonne `compte` est une référence libre au plan comptable
           (NVARCHAR(255) NULL, pas de FK — voir LigneBudget.java).
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P8-002-create-LigneBudget" author="microfina">
        <createTable tableName="LigneBudget">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_LigneBudget" nullable="false"/>
            </column>
            <column name="code_rubrique" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="libelle" type="NVARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type_ligne" type="NVARCHAR(10)" defaultValue="RECETTE">
                <constraints nullable="false"/>
            </column>
            <column name="montant_prevu" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="montant_realise" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="budget_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="compte" type="NVARCHAR(255)"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="FK_LigneBudget_Budget"
            baseTableName="LigneBudget"
            baseColumnNames="budget_id"
            referencedTableName="Budget"
            referencedColumnNames="id"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="LigneBudget"/>
            <dropTable tableName="LigneBudget"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
