<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P1-013-CREATE-TABLE-mode_de_calcul_interet" author="microfina">
        <comment>Create mode_de_calcul_interet table – interest calculation modes (Simple, Compound, Degressive)</comment>

        <createTable tableName="mode_de_calcul_interet">
            <column name="CODEMODE"     type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_mode_de_calcul_interet"/>
            </column>
            <column name="DESCRIPTION"  type="NVARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="MODECALCUL"   type="NVARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="VERSION"      type="INT" defaultValueNumeric="0"/>
        </createTable>

        <rollback>
            <dropTable tableName="mode_de_calcul_interet"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
