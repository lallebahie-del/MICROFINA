<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P1-017-CREATE-TABLE-comptabilite" author="microfina">
        <comment>Create comptabilite table – core accounting entries skeleton (debit/credit ledger)</comment>

        <createTable tableName="comptabilite">
            <column name="IDCOMPTABILITE"       type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_comptabilite"/>
            </column>
            <column name="CREDIT"               type="DECIMAL(19,4)"  defaultValueNumeric="0.0000"/>
            <column name="DATEOPERATION"        type="DATE"/>
            <column name="DATESERVEUR"          type="DATE"      defaultValueComputed="CAST(GETDATE() AS DATE)"/>
            <column name="DEBIT"                type="DECIMAL(19,4)"  defaultValueNumeric="0.0000"/>
            <column name="ENTREE"               type="DECIMAL(19,4)"  defaultValueNumeric="0.0000"/>
            <column name="ETAT"                 type="NVARCHAR(255)"/>
            <column name="ID"                   type="NVARCHAR(255)"/>
            <column name="LIBELLE"              type="NVARCHAR(255)"/>
            <column name="NPIECE"               type="NVARCHAR(20)"/>
            <column name="NUMCREDIT"            type="NVARCHAR(255)"/>
            <column name="NUMPIECE"             type="NVARCHAR(255)"/>
            <column name="REFERENCE"            type="NVARCHAR(255)"/>
            <column name="SORTIE"               type="DECIMAL(19,4)"  defaultValueNumeric="0.0000"/>
            <column name="TESTSUP"              type="NVARCHAR(255)"/>
            <column name="CODE_EMP"             type="NVARCHAR(48)"/>
            <column name="COMPTEDESTINATAIRE"   type="NVARCHAR(255)"/>
            <column name="DATEECHEANCE"         type="DATE"/>
            <column name="DATELETTRAGE"         type="DATE"/>
            <column name="DATEPIECE"            type="DATE"/>
            <column name="facture"              type="NVARCHAR(255)"/>
            <column name="LETTRE"               type="NVARCHAR(255)"/>
            <column name="MARQUE"               type="NVARCHAR(255)"/>
            <column name="numerocheque"         type="NVARCHAR(255)"/>
            <column name="PROVENANCE"           type="DECIMAL(19,4)"/>
            <column name="VERSION"              type="INT"            defaultValueNumeric="0"/>
            <column name="guichetDestinataire"  type="NVARCHAR(255)"/>
            <column name="guichetOrigine"       type="NVARCHAR(255)"/>
            <column name="CODECAISSE"           type="NVARCHAR(255)"/>
            <column name="planComptable"        type="NVARCHAR(15)"/>
            <column name="CompteAuxi"           type="NVARCHAR(25)"/>
            <column name="agence"               type="NVARCHAR(25)"/>
            <column name="compteTiers"          type="NVARCHAR(5)"/>
            <column name="journal"              type="BIGINT"/>
            <column name="Compte1"              type="NVARCHAR(15)"/>
            <column name="origine"              type="BIGINT"/>
            <column name="CODE_SENS"            type="NVARCHAR(255)"/>
            <column name="utilisateur"          type="NVARCHAR(48)"/>
            <column name="NUM_REGLEMENT_FOUR"   type="NVARCHAR(40)"/>
            <column name="NUM_REGLEMENT_CLIENT" type="NVARCHAR(40)"/>
            <column name="NUM_REGLEMENT"        type="NVARCHAR(25)"/>
            <column name="dateamort"            type="DATE"/>
            <column name="DATE_RAPPROCHEMENT"   type="DATE"/>
            <column name="CODE_BAILLEUR"        type="NVARCHAR(25)"/>
            <column name="CODE_BUDGET"          type="NVARCHAR(25)"/>
            <column name="TYPE_SUIVI"           type="NVARCHAR(15)"/>
            <column name="REFERENCE_SUIVI"      type="NVARCHAR(15)"/>
            <column name="CODE_TYPE_BUDGET"     type="NVARCHAR(15)"/>
            <!-- ID_LIGNE_PLAN_BUDGETAIRE: N (numeric), spec p.19 -->
            <column name="ID_LIGNE_PLAN_BUDGETAIRE" type="BIGINT"/>
            <!-- CODE_AGENCE: secondary branch reference, AN/25, spec p.19 -->
            <column name="CODE_AGENCE"          type="NVARCHAR(25)"/>
            <column name="agent_externe"        type="NVARCHAR(50)"/>
            <column name="CODE_LIGNE_BUDGETAIRE" type="NVARCHAR(50)"/>
            <column name="codeValidation"       type="NVARCHAR(20)"/>
            <column name="code_devise"          type="NVARCHAR(5)"/>
            <column name="CODE_COMPTE_EPARGNE"  type="NVARCHAR(255)"/>
            <column name="CODE_TIERS"           type="NVARCHAR(50)"/>
        </createTable>

        <!-- Index for fast lookup by operation date -->
        <createIndex tableName="comptabilite" indexName="IDX_comptabilite_DATEOPERATION">
            <column name="DATEOPERATION"/>
        </createIndex>

        <!-- Index for member account lookups -->
        <createIndex tableName="comptabilite" indexName="IDX_comptabilite_CompteAuxi">
            <column name="CompteAuxi"/>
        </createIndex>

        <!--
            FK on "agence" column (primary branch FK, mapped as @ManyToOne in Java).
            CODE_AGENCE is a secondary branch reference string and carries no FK constraint.
        -->
        <addForeignKeyConstraint
            baseTableName="comptabilite" baseColumnNames="agence"
            referencedTableName="AGENCE" referencedColumnNames="CODE_AGENCE"
            constraintName="FK_comptabilite_AGENCE"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="comptabilite"/>
            <dropIndex tableName="comptabilite" indexName="IDX_comptabilite_DATEOPERATION"/>
            <dropIndex tableName="comptabilite" indexName="IDX_comptabilite_CompteAuxi"/>
            <dropTable tableName="comptabilite"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
