<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  MICROFINA++ – Phase 1 Seed Data
  Populates: devise_local, mode_de_calcul_interet, FormeJuridique
  ============================================================
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ── devise_local: default currencies ─────────────────── -->
    <changeSet id="P1-SEED-001-devise_local" author="microfina">
        <comment>Seed default local currencies</comment>

        <insert tableName="devise_local">
            <column name="CODE_DEVISE" value="XOF"/>
            <column name="LIBELLE"     value="Franc CFA BCEAO (UEMOA)"/>
            <column name="SYMBOLE"     value="FCFA"/>
            <column name="ACTIF"       valueBoolean="true"/>
            <column name="TAUX_CHANGE" valueNumeric="1.0000"/>
            <column name="VERSION"     valueNumeric="0"/>
        </insert>

        <insert tableName="devise_local">
            <column name="CODE_DEVISE" value="XAF"/>
            <column name="LIBELLE"     value="Franc CFA BEAC (CEMAC)"/>
            <column name="SYMBOLE"     value="FCFA"/>
            <column name="ACTIF"       valueBoolean="true"/>
            <column name="TAUX_CHANGE" valueNumeric="1.0000"/>
            <column name="VERSION"     valueNumeric="0"/>
        </insert>

        <insert tableName="devise_local">
            <column name="CODE_DEVISE" value="EUR"/>
            <column name="LIBELLE"     value="Euro"/>
            <column name="SYMBOLE"     value="€"/>
            <column name="ACTIF"       valueBoolean="true"/>
            <column name="TAUX_CHANGE" valueNumeric="655.9570"/>
            <column name="VERSION"     valueNumeric="0"/>
        </insert>

        <insert tableName="devise_local">
            <column name="CODE_DEVISE" value="USD"/>
            <column name="LIBELLE"     value="Dollar américain"/>
            <column name="SYMBOLE"     value="$"/>
            <column name="ACTIF"       valueBoolean="true"/>
            <column name="TAUX_CHANGE" valueNumeric="600.0000"/>
            <column name="VERSION"     valueNumeric="0"/>
        </insert>

        <insert tableName="devise_local">
            <column name="CODE_DEVISE" value="MRU"/>
            <column name="LIBELLE"     value="Ouguiya Mauritanien"/>
            <column name="SYMBOLE"     value="UM"/>
            <column name="ACTIF"       valueBoolean="true"/>
            <column name="TAUX_CHANGE" valueNumeric="1.0000"/>
            <column name="VERSION"     valueNumeric="0"/>
        </insert>

        <rollback>
            <delete tableName="devise_local">
                <where>CODE_DEVISE IN ('XOF','XAF','EUR','USD','MRU')</where>
            </delete>
        </rollback>
    </changeSet>

    <!-- ── mode_de_calcul_interet: interest calculation modes ── -->
    <changeSet id="P1-SEED-002-mode_de_calcul_interet" author="microfina">
        <comment>Seed interest calculation modes: Simple, Compound (Composé), and Degressive</comment>

        <insert tableName="mode_de_calcul_interet">
            <column name="DESCRIPTION" value="Intérêt simple – calculé uniquement sur le capital initial"/>
            <column name="MODECALCUL"  value="SIMPLE"/>
            <column name="VERSION"     valueNumeric="0"/>
        </insert>

        <insert tableName="mode_de_calcul_interet">
            <column name="DESCRIPTION" value="Intérêt composé – calculé sur le capital + intérêts cumulés"/>
            <column name="MODECALCUL"  value="COMPOSE"/>
            <column name="VERSION"     valueNumeric="0"/>
        </insert>

        <insert tableName="mode_de_calcul_interet">
            <column name="DESCRIPTION" value="Intérêt dégressif – calculé sur le capital restant dû"/>
            <column name="MODECALCUL"  value="DEGRESSIF"/>
            <column name="VERSION"     valueNumeric="0"/>
        </insert>

        <insert tableName="mode_de_calcul_interet">
            <column name="DESCRIPTION" value="Taux fixe – mensualités constantes (annuité constante)"/>
            <column name="MODECALCUL"  value="FIXE"/>
            <column name="VERSION"     valueNumeric="0"/>
        </insert>

        <rollback>
            <delete tableName="mode_de_calcul_interet">
                <where>MODECALCUL IN ('SIMPLE','COMPOSE','DEGRESSIF','FIXE')</where>
            </delete>
        </rollback>
    </changeSet>

    <!-- ── FormeJuridique: standard legal forms ─────────────── -->
    <changeSet id="P1-SEED-003-FormeJuridique" author="microfina">
        <comment>Seed standard legal forms used for member and institutional classification</comment>

        <insert tableName="FormeJuridique">
            <column name="LIBELLE" value="Personne Physique"/>
            <column name="VERSION" valueNumeric="0"/>
        </insert>

        <insert tableName="FormeJuridique">
            <column name="LIBELLE" value="SARL – Société à Responsabilité Limitée"/>
            <column name="VERSION" valueNumeric="0"/>
        </insert>

        <insert tableName="FormeJuridique">
            <column name="LIBELLE" value="SA – Société Anonyme"/>
            <column name="VERSION" valueNumeric="0"/>
        </insert>

        <insert tableName="FormeJuridique">
            <column name="LIBELLE" value="SNC – Société en Nom Collectif"/>
            <column name="VERSION" valueNumeric="0"/>
        </insert>

        <insert tableName="FormeJuridique">
            <column name="LIBELLE" value="GIE – Groupement d'Intérêt Économique"/>
            <column name="VERSION" valueNumeric="0"/>
        </insert>

        <insert tableName="FormeJuridique">
            <column name="LIBELLE" value="Association Loi 1901"/>
            <column name="VERSION" valueNumeric="0"/>
        </insert>

        <insert tableName="FormeJuridique">
            <column name="LIBELLE" value="Coopérative"/>
            <column name="VERSION" valueNumeric="0"/>
        </insert>

        <insert tableName="FormeJuridique">
            <column name="LIBELLE" value="ONG – Organisation Non Gouvernementale"/>
            <column name="VERSION" valueNumeric="0"/>
        </insert>

        <insert tableName="FormeJuridique">
            <column name="LIBELLE" value="Entreprise Individuelle"/>
            <column name="VERSION" valueNumeric="0"/>
        </insert>

        <rollback>
            <delete tableName="FormeJuridique">
                <where>LIBELLE IN (
                    'Personne Physique',
                    'SARL – Société à Responsabilité Limitée',
                    'SA – Société Anonyme',
                    'SNC – Société en Nom Collectif',
                    'GIE – Groupement d''Intérêt Économique',
                    'Association Loi 1901',
                    'Coopérative',
                    'ONG – Organisation Non Gouvernementale',
