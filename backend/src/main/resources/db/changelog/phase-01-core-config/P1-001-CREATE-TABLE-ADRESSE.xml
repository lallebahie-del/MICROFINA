<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P1-001-CREATE-TABLE-ADRESSE" author="microfina">
        <comment>Create ADRESSE table – stores addresses for institutions, agencies, and members</comment>

        <createTable tableName="ADRESSE">
            <column name="IDADRESSE"          type="NVARCHAR(48)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_ADRESSE"/>
            </column>
            <column name="adresse"            type="NVARCHAR(255)"/>
            <column name="adresse1"           type="NVARCHAR(255)"/>
            <column name="BP"                 type="NVARCHAR(255)"/>
            <column name="descriptionAdresse" type="NVARCHAR(255)"/>
            <column name="DTYPE"              type="NVARCHAR(255)"/>
            <column name="email"              type="NVARCHAR(255)"/>
            <column name="fax"                type="NVARCHAR(255)"/>
            <column name="rueMaison"          type="NVARCHAR(255)"/>
            <column name="telephone"          type="NVARCHAR(255)"/>
            <column name="telephoneFixe"      type="NVARCHAR(255)"/>
            <column name="telephoneMobile"    type="NVARCHAR(255)"/>
            <column name="VERSION"            type="INT"          defaultValueNumeric="0"/>
            <column name="LATITUDE"           type="NVARCHAR(255)"/>
            <column name="LONGITUDE"          type="NVARCHAR(255)"/>
            <column name="indicateurTelMobile" type="INT"/>
        </createTable>

        <rollback>
            <dropTable tableName="ADRESSE"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
