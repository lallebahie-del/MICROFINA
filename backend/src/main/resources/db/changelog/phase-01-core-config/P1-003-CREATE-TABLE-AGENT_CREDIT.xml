<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P1-003-CREATE-TABLE-AGENT_CREDIT" author="microfina">
        <comment>Create AGENT_CREDIT table – credit agents who manage loan portfolios</comment>

        <createTable tableName="AGENT_CREDIT">
            <column name="CODE_AGENT"       type="NVARCHAR(25)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_AGENT_CREDIT"/>
            </column>
            <column name="code"             type="INT"/>
            <column name="codesuivi"        type="INT"/>
            <column name="duree1"           type="INT"/>
            <column name="duree2"           type="INT"/>
            <column name="actif"            type="NVARCHAR(255)"/>
            <column name="montant1"         type="DECIMAL(19,4)"/>
            <column name="Montant2"         type="DECIMAL(19,4)"/>
            <column name="DESIGNATION"      type="NVARCHAR(255)"/>
            <column name="VERSION"          type="INT"           defaultValueNumeric="0"/>
            <column name="ADRESSE_IDADRESSE" type="NVARCHAR(48)"/>
            <column name="CODE_AGENCE"      type="NVARCHAR(25)"/>
            <column name="UTILISATEUR"      type="NVARCHAR(48)"/>
            <column name="sysinfo"          type="NVARCHAR(200)"/>
            <column name="tlanguage"        type="NVARCHAR(5)"/>
            <column name="account"          type="NVARCHAR(20)"/>
            <column name="password"         type="NVARCHAR(100)"/>
            <column name="sexe_agent"       type="NVARCHAR(1)"/>
            <column name="tfunction"        type="NVARCHAR(100)"/>
            <column name="usercode"         type="NVARCHAR(100)"/>
            <!-- inuse: N (numeric 0/1), NOT BIT per spec -->
            <column name="inuse"            type="INT"           defaultValueNumeric="0"/>
            <column name="vdays"            type="INT"/>
            <column name="vstart"           type="DATE"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="AGENT_CREDIT" baseColumnNames="CODE_AGENCE"
            referencedTableName="AGENCE" referencedColumnNames="CODE_AGENCE"
            constraintName="FK_AGENT_CREDIT_AGENCE"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="AGENT_CREDIT"/>
            <dropTable tableName="AGENT_CREDIT"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
