<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P1-008-CREATE-TABLE-Parametre" author="microfina">
        <comment>Create Parametre table – member numbering nomenclature and system parameters</comment>

        <createTable tableName="Parametre">
            <column name="IDPARAMETRE"      type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_Parametre"/>
            </column>
            <column name="MAXIJOUROUVERT"               type="INT"/>
            <column name="ordreAgence"                  type="INT"/>
            <column name="ordreCategorie"               type="INT"/>
            <column name="ordreCompteur"                type="INT"/>
            <column name="ordreInstitution"             type="INT"/>
            <column name="ordrePrefixe"                 type="INT"/>
            <column name="ordreSuffixe"                 type="INT"/>
            <column name="positionAgence"               type="INT"/>
            <column name="positionCategorie"            type="INT"/>
            <column name="positionCompteur"             type="INT"/>
            <column name="positionInstitution"          type="INT"/>
            <column name="prefixe"                      type="NVARCHAR(255)"/>
            <column name="suffixe"                      type="NVARCHAR(255)"/>
            <column name="VERSION"                      type="INT"           defaultValueNumeric="0"/>
            <column name="fk_agence"                    type="NVARCHAR(25)"/>
            <column name="fk_categorie"                 type="NVARCHAR(25)"/>
            <column name="fk_compteurMembre_categorie"  type="NVARCHAR(25)"/>
            <column name="fk_compteurMembre_institution" type="NVARCHAR(255)"/>
            <column name="fk_compteurMembre_agence"     type="NVARCHAR(5)"/>
            <column name="fk_institution"               type="NVARCHAR(255)"/>
            <column name="ID_COMPTEUR_MEMBRE"           type="BIGINT"/>
            <column name="use_multidevise"              type="NVARCHAR(1)"   defaultValue="N"/>
            <column name="note_absence_deductible"      type="NVARCHAR(255)"/>
            <column name="note_absence_non_deductible"  type="NVARCHAR(255)"/>
            <column name="note_absence_non_deductible_complement" type="NVARCHAR(255)"/>
            <column name="note_interruption_absence"    type="NVARCHAR(255)"/>
            <!-- compteurCollecteur: N type → BIGINT for large counters -->
            <column name="compteurCollecteur"           type="BIGINT"/>
            <column name="comptePEL"                    type="NVARCHAR(15)"/>
            <column name="compteInteretPEL"             type="NVARCHAR(15)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="Parametre" baseColumnNames="fk_agence"
            referencedTableName="AGENCE" referencedColumnNames="CODE_AGENCE"
            constraintName="FK_Parametre_AGENCE"/>

        <addForeignKeyConstraint
            baseTableName="Parametre" baseColumnNames="fk_institution"
            referencedTableName="institution" referencedColumnNames="CODE_INSTITUTION"
            constraintName="FK_Parametre_institution"/>

        <addForeignKeyConstraint
            baseTableName="Parametre" baseColumnNames="ID_COMPTEUR_MEMBRE"
            referencedTableName="CompteurMembre" referencedColumnNames="ID_COMPTEUR_MEMBRE"
            constraintName="FK_Parametre_CompteurMembre"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="Parametre"/>
            <dropTable tableName="Parametre"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
