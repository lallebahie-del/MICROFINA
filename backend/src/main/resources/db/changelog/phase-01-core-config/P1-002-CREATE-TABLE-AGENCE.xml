<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P1-002-CREATE-TABLE-AGENCE" author="microfina">
        <comment>Create AGENCE table – branch/agency configuration for the MFI</comment>

        <createTable tableName="AGENCE">
            <column name="CODE_AGENCE"              type="NVARCHAR(25)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_AGENCE"/>
            </column>
            <column name="ACTIF"                    type="BIT"           defaultValueBoolean="true"/>
            <column name="basecommune"              type="NVARCHAR(255)"/>
            <column name="baseDeDonnee"             type="NVARCHAR(255)"/>
            <column name="Bordereau"                type="BIT"           defaultValueBoolean="false"/>
            <column name="COMPTE_CREDITEUR"         type="NVARCHAR(255)"/>
            <column name="Compteur"                 type="INT"/>
            <column name="dbDriver"                 type="NVARCHAR(255)"/>
            <column name="ISSIEGE"                  type="NVARCHAR(1)"/>
            <column name="login"                    type="NVARCHAR(255)"/>
            <column name="NOMAGENCE"                type="NVARCHAR(255)"/>
            <column name="NUMAGENCE"                type="NVARCHAR(255)"/>
            <column name="NUMERO_SMS"               type="NVARCHAR(255)"/>
            <column name="passWord"                 type="NVARCHAR(255)"/>
            <column name="port"                     type="NVARCHAR(255)"/>
            <column name="PREF"                     type="NVARCHAR(255)"/>
            <column name="schemas"                  type="NVARCHAR(255)"/>
            <column name="serveur"                  type="NVARCHAR(255)"/>
            <column name="SUFF"                     type="NVARCHAR(255)"/>
            <column name="VERSION"                  type="INT"           defaultValueNumeric="0"/>
            <column name="institution"              type="NVARCHAR(255)"/>
            <column name="zoneGeographique"         type="INT"/>
            <column name="ADRESSE_IDADRESSE"        type="NVARCHAR(48)"/>
            <column name="chefAgence"               type="NVARCHAR(48)"/>
            <column name="NUMCOMPTE"                type="NVARCHAR(15)"/>
            <column name="PATH"                     type="NVARCHAR(100)"/>
            <column name="PATH_PHOTO_REEL"          type="NVARCHAR(100)"/>
            <column name="PATH_PHOTO_SIMPLE"        type="NVARCHAR(100)"/>
            <column name="PATH_SIGNATURE_SIMPLE"    type="NVARCHAR(100)"/>
            <column name="PATH_SIGNATURE_REEL"      type="NVARCHAR(100)"/>
            <column name="devise_local"             type="NVARCHAR(10)"/>
            <column name="compteCaisse"             type="NVARCHAR(30)"/>
            <column name="sufixe_compte"            type="NVARCHAR(30)"/>
            <column name="MAX_MONT_DECAISS_CAISSE"          type="DECIMAL(19,4)"/>
            <column name="MIN_MONT_DECAISS_CAISSE"          type="DECIMAL(19,4)"/>
            <column name="MAX_MONT_DECAISS_BANQUE_PRELEV"   type="DECIMAL(19,4)"/>
            <column name="MIN_MONT_DECAISS_BANQUE_PRELEV"   type="DECIMAL(19,4)"/>
            <column name="filte_mbre_mobile"        type="BIT"           defaultValueBoolean="false"/>
            <column name="daterref_debut_penalite"  type="DATE"/>
            <column name="longitude"                type="DECIMAL(19,4)"/>
            <column name="latitude"                 type="DECIMAL(19,4)"/>
            <column name="DERNIERE_JRNEE_OUVERTE"   type="DATE"/>
            <column name="nom_court"                type="NVARCHAR(100)"/>
            <column name="indiceMembre"             type="INT"/>
            <column name="indicecarnet"             type="INT"/>
            <column name="NOM_PRENOM_CHEF_AGENCE"   type="NVARCHAR(255)"/>
            <column name="liaison_trsfInterne"      type="NVARCHAR(15)"/>
            <column name="liaison_virement"         type="NVARCHAR(15)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="AGENCE" baseColumnNames="ADRESSE_IDADRESSE"
            referencedTableName="ADRESSE" referencedColumnNames="IDADRESSE"
            constraintName="FK_AGENCE_ADRESSE"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="AGENCE"/>
            <dropTable tableName="AGENCE"/>
        </rollback>
    </changeSet>

    <changeSet id="P1-006b-FK-AGENCE-devise_local" author="microfina">
        <comment>FK: AGENCE.devise_local → devise_local, institution.devise_principale → devise_local</comment>
        <addForeignKeyConstraint
            baseTableName="AGENCE"      baseColumnNames="devise_local"
            referencedTableName="devise_local" referencedColumnNames="CODE_DEVISE"
            constraintName="FK_AGENCE_devise_local"/>
        <addForeignKeyConstraint
            baseTableName="institution" baseColumnNames="devise_principale"
            referencedTableName="devise_local" referencedColumnNames="CODE_DEVISE"
            constraintName="FK_institution_devise_principale"/>
        <rollback>
            <dropForeignKeyConstraint baseTableName="AGENCE"      constraintName="FK_AGENCE_devise_local"/>
            <dropForeignKeyConstraint baseTableName="institution"  constraintName="FK_institution_devise_principale"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
