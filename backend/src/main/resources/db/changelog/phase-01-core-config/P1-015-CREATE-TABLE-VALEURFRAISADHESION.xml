<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P1-015 – VALEURFRAISADHESION  (NO-OP)
        Architecture decision: switched from JOINED to SINGLE_TABLE inheritance.
        ValeurFraisAdhesion is a JPA subtype of ValeurFrais sharing the same table.
        The adhesion-specific columns (formeJuridique, age_min, age_max) were added
        directly to the ValeurFrais table in P1-014.
        No separate VALEURFRAISADHESION table is created.
    -->
    <changeSet id="P1-015-VALEURFRAISADHESION-NOOP" author="microfina">
        <comment>
            No-op placeholder. ValeurFraisAdhesion uses SINGLE_TABLE inheritance
            and lives inside the ValeurFrais table (see P1-014).
        </comment>
        <sql>-- No DDL required: ValeurFraisAdhesion is mapped via SINGLE_TABLE in ValeurFrais</sql>
        <rollback><!-- nothing to roll back --></rollback>
    </changeSet>

</databaseChangeLog>
