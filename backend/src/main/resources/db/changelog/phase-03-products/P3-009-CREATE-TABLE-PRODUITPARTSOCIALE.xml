<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P3-009 – PRODUITPARTSOCIALE
        Social-share product (Part Sociale / Capital social): defines the nominal
        value per share, min/max shares per member, dividend rate, and the
        accounting accounts used to post share subscriptions and dividends.

        FK dependencies:
          FamillePartSociale (CODEFAMILLEPARTSOCIALE) – Phase 1
        DDL source of truth: Phase 3 spec – Section 3.
    -->
    <changeSet id="P3-009-create-PRODUITPARTSOCIALE" author="microfina">

        <createTable tableName="PRODUITPARTSOCIALE">

            <!-- PK – short product code e.g. "PPS001" -->
            <column name="NUMPRODUIT" type="NVARCHAR(50)">
                <constraints primaryKey="true"
                             primaryKeyName="PK_PRODUITPARTSOCIALE"
                             nullable="false"/>
            </column>

            <!-- ── Identity ───────────────────────────────────────── -->
            <column name="NOMPRODUIT" type="NVARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <column name="DESCRIPTION" type="NVARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <column name="ACTIF" type="INT" defaultValueNumeric="1">
                <constraints nullable="true"/>
            </column>

            <!-- ── Share parameters ───────────────────────────────── -->
            <!-- Nominal value per share (e.g. 5000 XOF) -->
            <column name="VALEUR_NOMINALE" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- Minimum number of shares a member must hold -->
            <column name="NOMBRE_PARTS_MIN" type="INT">
                <constraints nullable="true"/>
            </column>

            <!-- Maximum number of shares a member may hold -->
            <column name="NOMBRE_PARTS_MAX" type="INT">
                <constraints nullable="true"/>
            </column>

            <!-- ── Dividend ────────────────────────────────────────── -->
            <column name="TAUX_DIVIDENDE" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- ANNUEL, SEMESTRIEL, etc. -->
            <column name="PERIODICITE_DIVIDENDE" type="NVARCHAR(50)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Accounting accounts ────────────────────────────── -->
            <column name="COMPTE_CAPITAL_SOCIAL" type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <column name="COMPTE_DIVIDENDE" type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <column name="COMPTE_RESERVE" type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <!-- Account for partial withdrawal / remboursement de parts -->
            <column name="COMPTE_REMBOURSEMENT" type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Transfer / exit rules ─────────────────────────── -->
            <!-- 1 = shares may be transferred between members -->
            <column name="TRANSFERT_AUTORISE" type="INT" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>

            <!-- Minimum holding period before withdrawal is allowed (months) -->
            <column name="DUREE_INDISPONIBILITE" type="INT">
                <constraints nullable="true"/>
            </column>

            <!-- ── Optimistic lock ────────────────────────────────── -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <rollback>
            <dropTable tableName="PRODUITPARTSOCIALE"/>
        </rollback>

    </changeSet>

    <!-- FK → FamillePartSociale (Phase 1) -->
    <changeSet id="P3-009-fk-PRODUITPARTSOCIALE-FamillePartSociale" author="microfina">

        <addColumn tableName="PRODUITPARTSOCIALE">
            <column name="codefamillepartsociale" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint
            constraintName           = "FK_PRODUITPARTSOCIALE_FamillePartSociale"
            baseTableName            = "PRODUITPARTSOCIALE"
            baseColumnNames          = "codefamillepartsociale"
            referencedTableName      = "FAMILLEPARTSOCIALE"
            referencedColumnNames    = "IDFAMILLEPARTSOCIALE"
            onDelete                 = "SET NULL"
            onUpdate                 = "CASCADE"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="PRODUITPARTSOCIALE"
                                      constraintName="FK_PRODUITPARTSOCIALE_FamillePartSociale"/>
            <dropColumn tableName="PRODUITPARTSOCIALE" columnName="codefamillepartsociale"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
