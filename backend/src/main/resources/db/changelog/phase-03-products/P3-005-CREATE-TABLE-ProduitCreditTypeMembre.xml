<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P3-005 – ProduitCreditTypeMembre
        Restricts a credit product to specific member types (Personne Physique,
        Personne Morale, Groupe Solidaire, etc.).
        2-column composite PK: (numproduit, typemembre).

        FK dependencies:
          produitcredit (NUMPRODUIT) – Phase 3
        DDL source of truth: Phase 3 spec – Section 1.
    -->
    <changeSet id="P3-005-create-ProduitCreditTypeMembre" author="microfina">

        <createTable tableName="ProduitCreditTypeMembre">

            <!-- ── Composite PK col 1: credit product ─────────────── -->
            <column name="numproduit" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <!-- ── Composite PK col 2: member type code ───────────── -->
            <!-- e.g. PP=Personne Physique, PM=Personne Morale, GS=Groupe Solidaire -->
            <column name="typemembre" type="NVARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <!-- Optional label for the type -->
            <column name="libelle_type_membre" type="NVARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <!-- 1 = combination is active -->
            <column name="actif" type="INT" defaultValueNumeric="1">
                <constraints nullable="true"/>
            </column>

            <!-- Optimistic lock -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- 2-column composite PK -->
        <addPrimaryKey
            tableName       = "ProduitCreditTypeMembre"
            columnNames     = "numproduit, typemembre"
            constraintName  = "PK_ProduitCreditTypeMembre"/>

        <rollback>
            <dropTable tableName="ProduitCreditTypeMembre"/>
        </rollback>

    </changeSet>

    <!-- FK → produitcredit -->
    <changeSet id="P3-005-fk-ProduitCreditTypeMembre-produitcredit" author="microfina">

        <addForeignKeyConstraint
            constraintName           = "FK_ProduitCreditTypeMembre_produitcredit"
            baseTableName            = "ProduitCreditTypeMembre"
            baseColumnNames          = "numproduit"
            referencedTableName      = "produitcredit"
            referencedColumnNames    = "NUMPRODUIT"
            onDelete                 = "CASCADE"
            onUpdate                 = "CASCADE"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="ProduitCreditTypeMembre"
                                      constraintName="FK_ProduitCreditTypeMembre_produitcredit"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
