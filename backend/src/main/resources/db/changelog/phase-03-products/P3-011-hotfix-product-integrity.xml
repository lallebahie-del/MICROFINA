<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P3-011 – Hotfix: product referential-integrity fixes
        Architect-mandated pre-Phase-4 corrections.

        Fix 1 – Width alignment + FK wiring
        ─────────────────────────────────────────────────────────────────
        CATEGORIE_PRODUIT_CREDIT.CODE_PRODUIT_CREDIT was NVARCHAR(25).
        produitcredit.NUMPRODUIT (Phase 3) is NVARCHAR(20).
        Column must be narrowed to 20 before the FK can be enforced.

        Fix 2 – Islamic finance ratio columns (§3.1.1)
        ─────────────────────────────────────────────────────────────────
        Three new nullable DECIMAL(19,4) columns on produit_islamic:
          cost_price_ratio     – Mourabaha: acquisition cost share
          markup_ratio         – Mourabaha: profit margin applied on cost
          residual_value_ratio – Ijara: residual asset value at contract end
    -->

    <!-- ═══════════════════════════════════════════════════════
         Fix 1a – Narrow CODE_PRODUIT_CREDIT to NVARCHAR(20)
         Must run before the FK constraint is added.
         ═══════════════════════════════════════════════════════ -->
    <changeSet id="P3-011-alter-CATEGORIE_PRODUIT_CREDIT-width" author="microfina">
        <comment>
            Align CATEGORIE_PRODUIT_CREDIT.CODE_PRODUIT_CREDIT width with
            produitcredit.NUMPRODUIT (NVARCHAR 25 → 20).
            Requires dropping the PK in SQL Server.
        </comment>

        <dropPrimaryKey
            tableName="CATEGORIE_PRODUIT_CREDIT"
            constraintName="PK_CATEGORIE_PRODUIT_CREDIT"/>

        <modifyDataType
            tableName  = "CATEGORIE_PRODUIT_CREDIT"
            columnName = "CODE_PRODUIT_CREDIT"
            newDataType= "NVARCHAR(20)"/>

        <addNotNullConstraint
            tableName="CATEGORIE_PRODUIT_CREDIT"
            columnName="CODE_PRODUIT_CREDIT"
            columnDataType="NVARCHAR(20)"/>

        <addPrimaryKey
            tableName="CATEGORIE_PRODUIT_CREDIT"
            columnNames="CODE_CATEGORIE, CODE_PRODUIT_CREDIT"
            constraintName="PK_CATEGORIE_PRODUIT_CREDIT"/>

        <rollback>
            <dropPrimaryKey
                tableName="CATEGORIE_PRODUIT_CREDIT"
                constraintName="PK_CATEGORIE_PRODUIT_CREDIT"/>

            <modifyDataType
                tableName  = "CATEGORIE_PRODUIT_CREDIT"
                columnName = "CODE_PRODUIT_CREDIT"
                newDataType= "NVARCHAR(25)"/>

            <addNotNullConstraint
                tableName="CATEGORIE_PRODUIT_CREDIT"
                columnName="CODE_PRODUIT_CREDIT"
                columnDataType="NVARCHAR(25)"/>

            <addPrimaryKey
                tableName="CATEGORIE_PRODUIT_CREDIT"
                columnNames="CODE_CATEGORIE, CODE_PRODUIT_CREDIT"
                constraintName="PK_CATEGORIE_PRODUIT_CREDIT"/>
        </rollback>
    </changeSet>

    <!-- ═══════════════════════════════════════════════════════
         Fix 1b – Add FK from CATEGORIE_PRODUIT_CREDIT → produitcredit
         ═══════════════════════════════════════════════════════ -->
    <changeSet id="P3-011-fk-CATEGORIE_PRODUIT_CREDIT-produitcredit" author="microfina">
        <comment>
            Enforce referential integrity: every CODE_PRODUIT_CREDIT value in
            CATEGORIE_PRODUIT_CREDIT must exist in produitcredit.NUMPRODUIT.
        </comment>

        <addForeignKeyConstraint
            constraintName        = "FK_CATEGORIE_PRODUIT_CREDIT_produitcredit"
            baseTableName         = "CATEGORIE_PRODUIT_CREDIT"
            baseColumnNames       = "CODE_PRODUIT_CREDIT"
            referencedTableName   = "produitcredit"
            referencedColumnNames = "NUMPRODUIT"
            onDelete                 = "NO ACTION"
            onUpdate              = "CASCADE"/>

        <rollback>
            <dropForeignKeyConstraint
                baseTableName  = "CATEGORIE_PRODUIT_CREDIT"
                constraintName = "FK_CATEGORIE_PRODUIT_CREDIT_produitcredit"/>
        </rollback>
    </changeSet>

    <!-- ═══════════════════════════════════════════════════════
         Fix 2 – Islamic finance ratio columns (§3.1.1)
         ═══════════════════════════════════════════════════════ -->
    <changeSet id="P3-011-add-produit_islamic-ratio-columns" author="microfina">
        <comment>
            §3.1.1 – Add Mourabaha / Ijara ratio columns to produit_islamic.
            All nullable; populated only for the relevant contract types.
        </comment>

        <addColumn tableName="produit_islamic">

            <!--
                Mourabaha: proportion of the total amount representing the
                institution's acquisition cost (0 < cost_price_ratio ≤ 1).
            -->
            <column name="cost_price_ratio" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!--
                Mourabaha: profit margin applied on top of the acquisition cost.
                Effective price = cost_price_ratio × (1 + markup_ratio).
            -->
            <column name="markup_ratio" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!--
                Ijara: proportion of the asset value remaining at contract end
                (used to compute the residual purchase option price).
            -->
            <column name="residual_value_ratio" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

        </addColumn>

        <rollback>
            <dropColumn tableName="produit_islamic" columnName="cost_price_ratio"/>
            <dropColumn tableName="produit_islamic" columnName="markup_ratio"/>
            <dropColumn tableName="produit_islamic" columnName="residual_value_ratio"/>
        </rollback>

    </changeSet>

</databaseChangeLog>