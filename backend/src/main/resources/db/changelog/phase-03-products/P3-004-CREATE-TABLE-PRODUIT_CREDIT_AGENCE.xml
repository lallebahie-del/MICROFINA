<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P3-004 – PRODUIT_CREDIT_AGENCE
        Junction table: restricts a credit product to specific branches (agences)
        and optionally to a specific credit object code.
        3-column composite PK: (CODE_AGENCE, NUMPDTCREDIT, CODE_OBJET_CREDIT).

        FK dependencies:
          produitcredit (NUMPRODUIT)   – Phase 3
          AGENCE (CODE_AGENCE)         – Phase 1
        DDL source of truth: Phase 3 spec – Section 1.
    -->
    <changeSet id="P3-004-create-PRODUIT_CREDIT_AGENCE" author="microfina">

        <createTable tableName="PRODUIT_CREDIT_AGENCE">

            <!-- ── Composite PK column 1: branch ─────────────────── -->
            <column name="CODE_AGENCE" type="NVARCHAR(25)">
                <constraints nullable="false"/>
            </column>

            <!-- ── Composite PK column 2: credit product ─────────── -->
            <column name="NUMPDTCREDIT" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <!-- ── Composite PK column 3: credit object code ──────── -->
            <!-- e.g. "HAB"=Habitat, "AGR"=Agriculture; can be empty string -->
            <column name="CODE_OBJET_CREDIT" type="NVARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <!-- ── Optional overrides per branch ─────────────────── -->
            <column name="MONTANTMIN" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <column name="MONTANTMAX" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <column name="TAUXINTERET" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <column name="ACTIF" type="INT" defaultValueNumeric="1">
                <constraints nullable="true"/>
            </column>

            <!-- Optimistic lock -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- 3-column composite PK -->
        <addPrimaryKey
            tableName       = "PRODUIT_CREDIT_AGENCE"
            columnNames     = "CODE_AGENCE, NUMPDTCREDIT, CODE_OBJET_CREDIT"
            constraintName  = "PK_PRODUIT_CREDIT_AGENCE"/>

        <rollback>
            <dropTable tableName="PRODUIT_CREDIT_AGENCE"/>
        </rollback>

    </changeSet>

    <!-- FK → AGENCE -->
    <changeSet id="P3-004-fk-PRODUIT_CREDIT_AGENCE-agence" author="microfina">

        <addForeignKeyConstraint
            constraintName           = "FK_PRODUIT_CREDIT_AGENCE_AGENCE"
            baseTableName            = "PRODUIT_CREDIT_AGENCE"
            baseColumnNames          = "CODE_AGENCE"
            referencedTableName      = "AGENCE"
            referencedColumnNames    = "CODE_AGENCE"
            onDelete                 = "CASCADE"
            onUpdate                 = "CASCADE"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="PRODUIT_CREDIT_AGENCE"
                                      constraintName="FK_PRODUIT_CREDIT_AGENCE_AGENCE"/>
        </rollback>

    </changeSet>

    <!-- FK → produitcredit -->
    <changeSet id="P3-004-fk-PRODUIT_CREDIT_AGENCE-produitcredit" author="microfina">

        <addForeignKeyConstraint
            constraintName           = "FK_PRODUIT_CREDIT_AGENCE_produitcredit"
            baseTableName            = "PRODUIT_CREDIT_AGENCE"
            baseColumnNames          = "NUMPDTCREDIT"
            referencedTableName      = "produitcredit"
            referencedColumnNames    = "NUMPRODUIT"
            onDelete                 = "CASCADE"
            onUpdate                 = "CASCADE"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="PRODUIT_CREDIT_AGENCE"
                                      constraintName="FK_PRODUIT_CREDIT_AGENCE_produitcredit"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
