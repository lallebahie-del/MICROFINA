<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P12-002 – analyse_financiere

        Captures the financial analysis (revenus / charges / ratios) attached to a
        credit dossier. Required input for the COMITE step. Modeled as a 1-1 with
        Credits keyed by credit_id (UNIQUE) to keep things simple — the legacy
        AnalyseFinanciereInferieure / AnalyseFinanciereSuperieure split is
        collapsed into TYPE_ANALYSE for now.

        FK dependencies:
            Credits (IDCREDIT) – P4-001
    -->
    <changeSet id="P12-002-create-analyse_financiere" author="microfina-phase12">
        <comment>Create analyse_financiere — financial analysis attached to a credit dossier</comment>

        <createTable tableName="analyse_financiere">

            <!-- ── PK ──────────────────────────────────────────────── -->
            <column name="ID_ANALYSE" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_analyse_financiere"
                             nullable="false"/>
            </column>

            <!-- ── FK → Credits ────────────────────────────────────── -->
            <column name="credit_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <!-- INFERIEURE | SUPERIEURE — based on amount threshold per legacy spec -->
            <column name="TYPE_ANALYSE" type="NVARCHAR(15)" defaultValue="INFERIEURE">
                <constraints nullable="false"/>
            </column>

            <!-- ── Income / charges (monthly) ──────────────────────── -->
            <column name="REVENUS_MENSUELS" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="CHARGES_MENSUELLES" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- Calculated by service: REVENUS - CHARGES -->
            <column name="CAPACITE_REMBOURSEMENT" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- Calculated by service: CHARGES / REVENUS (0..1) -->
            <column name="RATIO_ENDETTEMENT" type="DECIMAL(9,4)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Bilan ──────────────────────────────────────────── -->
            <column name="TOTAL_ACTIF" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="TOTAL_PASSIF" type="DECIMAL(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- ── Indicateurs / commentary ───────────────────────── -->
            <column name="INDICATEURS_JSON" type="NVARCHAR(MAX)">
                <constraints nullable="true"/>
            </column>

            <column name="COMMENTAIRE" type="NVARCHAR(2000)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Decision support ───────────────────────────────── -->
            <!-- FAVORABLE | DEFAVORABLE | RESERVE -->
            <column name="AVIS_AGENT" type="NVARCHAR(15)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Audit ──────────────────────────────────────────── -->
            <column name="DATE_ANALYSE" type="DATETIME2" defaultValueComputed="SYSUTCDATETIME()">
                <constraints nullable="false"/>
            </column>

            <column name="UTILISATEUR" type="NVARCHAR(48)">
                <constraints nullable="true"/>
            </column>

            <!-- Optimistic lock -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- 1-1 with Credits — only one analyse_financiere per credit -->
        <addUniqueConstraint
            tableName      = "analyse_financiere"
            columnNames    = "credit_id"
            constraintName = "UQ_analyse_financiere_credit"/>

        <addForeignKeyConstraint
            constraintName        = "FK_analyse_financiere_Credits"
            baseTableName         = "analyse_financiere"
            baseColumnNames       = "credit_id"
            referencedTableName   = "Credits"
            referencedColumnNames = "IDCREDIT"
            onDelete              = "CASCADE"
            onUpdate              = "NO ACTION"/>

        <rollback>
            <dropTable tableName="analyse_financiere"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
