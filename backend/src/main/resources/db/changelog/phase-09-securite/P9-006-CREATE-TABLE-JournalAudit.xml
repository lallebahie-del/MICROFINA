<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P9-006-create-JournalAudit" author="microfina">
        <comment>Create JournalAudit table – immutable audit trail for all domain actions; no FK to Utilisateur intentionally</comment>

        <createTable tableName="JournalAudit">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_JournalAudit"/>
            </column>
            <column name="date_action" type="DATETIME2">
                <constraints nullable="false"/>
            </column>
            <column name="utilisateur" type="NVARCHAR(100)"/>
            <column name="action" type="NVARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="entite" type="NVARCHAR(100)"/>
            <column name="id_entite" type="NVARCHAR(100)"/>
            <column name="ancienne_valeur" type="NVARCHAR(MAX)"/>
            <column name="nouvelle_valeur" type="NVARCHAR(MAX)"/>
            <column name="adresse_ip" type="NVARCHAR(45)"/>
            <column name="user_agent" type="NVARCHAR(500)"/>
            <column name="version" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex
            tableName="JournalAudit"
            indexName="IDX_JournalAudit_date_user">
            <column name="date_action"/>
            <column name="utilisateur"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="JournalAudit" indexName="IDX_JournalAudit_date_user"/>
            <dropTable tableName="JournalAudit"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
