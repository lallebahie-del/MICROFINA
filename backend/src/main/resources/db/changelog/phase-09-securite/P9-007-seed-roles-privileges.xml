<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================
         P9-007-A : Seed des rôles de base
         ================================================================ -->
    <changeSet id="P9-007-seed-roles" author="microfina">
        <comment>Seed initial roles into the Role table</comment>

        <insert tableName="Role">
            <column name="code_role" value="ADMIN"/>
            <column name="libelle"   value="Administrateur système"/>
            <column name="description" value="Accès complet à toutes les fonctionnalités du système, gestion des utilisateurs et des paramètres globaux"/>
            <column name="version"   valueNumeric="0"/>
        </insert>

        <insert tableName="Role">
            <column name="code_role" value="AGENT_CREDIT"/>
            <column name="libelle"   value="Agent de crédit"/>
            <column name="description" value="Instruction et suivi des dossiers de crédit"/>
            <column name="version"   valueNumeric="0"/>
        </insert>

        <insert tableName="Role">
            <column name="code_role" value="CAISSIER"/>
            <column name="libelle"   value="Caissier"/>
            <column name="description" value="Gestion des opérations de caisse, dépôts et retraits"/>
            <column name="version"   valueNumeric="0"/>
        </insert>

        <insert tableName="Role">
            <column name="code_role" value="COMPTABLE"/>
            <column name="libelle"   value="Comptable"/>
            <column name="description" value="Saisie et validation des écritures comptables, suivi budgétaire"/>
            <column name="version"   valueNumeric="0"/>
        </insert>

        <insert tableName="Role">
            <column name="code_role" value="COMITE_CREDIT"/>
            <column name="libelle"   value="Comité de crédit"/>
            <column name="description" value="Validation et rejet des dossiers de crédit soumis par les agents"/>
            <column name="version"   valueNumeric="0"/>
        </insert>

        <insert tableName="Role">
            <column name="code_role" value="SUPERVISEUR"/>
            <column name="libelle"   value="Superviseur"/>
            <column name="description" value="Supervision des opérations quotidiennes et clôture de journée"/>
            <column name="version"   valueNumeric="0"/>
        </insert>

        <insert tableName="Role">
            <column name="code_role" value="AUDITEUR"/>
            <column name="libelle"   value="Auditeur interne"/>
            <column name="description" value="Consultation en lecture seule du journal d'audit et des rapports"/>
            <column name="version"   valueNumeric="0"/>
        </insert>

        <rollback>
            <delete tableName="Role">
                <where>code_role IN ('ADMIN','AGENT_CREDIT','CAISSIER','COMPTABLE','COMITE_CREDIT','SUPERVISEUR','AUDITEUR')</where>
            </delete>
        </rollback>
    </changeSet>

    <!-- ================================================================
         P9-007-B : Seed des privilèges de base
         ================================================================ -->
    <changeSet id="P9-007-seed-privileges" author="microfina">
        <comment>Seed initial privileges into the Privilege table, grouped by module</comment>

        <!-- Module CREDIT -->
        <insert tableName="Privilege">
            <column name="code_privilege" value="CREATE_CREDIT"/>
            <column name="libelle"        value="Créer un dossier de crédit"/>
            <column name="module"         value="CREDIT"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="VALIDATE_CREDIT"/>
            <column name="libelle"        value="Valider un dossier de crédit"/>
            <column name="module"         value="CREDIT"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="DISBURSE_CREDIT"/>
            <column name="libelle"        value="Décaisser un crédit accordé"/>
            <column name="module"         value="CREDIT"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="REJECT_CREDIT"/>
            <column name="libelle"        value="Rejeter un dossier de crédit"/>
            <column name="module"         value="CREDIT"/>
            <column name="version"        valueNumeric="0"/>
        </insert>

        <!-- Module CAISSE -->
        <insert tableName="Privilege">
            <column name="code_privilege" value="POST_REGLEMENT"/>
            <column name="libelle"        value="Enregistrer un règlement de crédit en caisse"/>
            <column name="module"         value="CAISSE"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="OPEN_COMPTE_EPS"/>
            <column name="libelle"        value="Ouvrir un compte d'épargne"/>
            <column name="module"         value="CAISSE"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="DEPOSIT_EPARGNE"/>
            <column name="libelle"        value="Effectuer un dépôt sur un compte d'épargne"/>
            <column name="module"         value="CAISSE"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="WITHDRAW_EPARGNE"/>
            <column name="libelle"        value="Effectuer un retrait sur un compte d'épargne"/>
            <column name="module"         value="CAISSE"/>
            <column name="version"        valueNumeric="0"/>
        </insert>

        <!-- Module BANQUE -->
        <insert tableName="Privilege">
            <column name="code_privilege" value="BANK_OPERATION"/>
            <column name="libelle"        value="Enregistrer une opération bancaire"/>
            <column name="module"         value="BANQUE"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="MANAGE_CHEQUE"/>
            <column name="libelle"        value="Gérer les chèques (émission, remise, opposition)"/>
            <column name="module"         value="BANQUE"/>
            <column name="version"        valueNumeric="0"/>
        </insert>

        <!-- Module BUDGET -->
        <insert tableName="Privilege">
            <column name="code_privilege" value="CREATE_BUDGET"/>
            <column name="libelle"        value="Créer un budget prévisionnel"/>
            <column name="module"         value="BUDGET"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="VALIDATE_BUDGET"/>
            <column name="libelle"        value="Valider un budget prévisionnel"/>
            <column name="module"         value="BUDGET"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="RECORD_MOVEMENT"/>
            <column name="libelle"        value="Enregistrer un mouvement budgétaire"/>
            <column name="module"         value="BUDGET"/>
            <column name="version"        valueNumeric="0"/>
        </insert>

        <!-- Module ADMIN -->
        <insert tableName="Privilege">
            <column name="code_privilege" value="CLOSE_DAY"/>
            <column name="libelle"        value="Effectuer la clôture de journée"/>
            <column name="module"         value="ADMIN"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="MANAGE_USERS"/>
            <column name="libelle"        value="Gérer les utilisateurs et leurs droits"/>
            <column name="module"         value="ADMIN"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="VIEW_AUDIT"/>
            <column name="libelle"        value="Consulter le journal d'audit"/>
            <column name="module"         value="ADMIN"/>
            <column name="version"        valueNumeric="0"/>
        </insert>

        <!-- Module REPORTING -->
        <insert tableName="Privilege">
            <column name="code_privilege" value="VIEW_REPORTS"/>
            <column name="libelle"        value="Consulter les rapports et tableaux de bord"/>
            <column name="module"         value="REPORTING"/>
            <column name="version"        valueNumeric="0"/>
        </insert>
        <insert tableName="Privilege">
            <column name="code_privilege" value="EXPORT_REPORTS"/>
            <column name="libelle"        value="Exporter les rapports (PDF, Excel)"/>
            <column name="module"         value="REPORTING"/>
            <column name="version"        valueNumeric="0"/>
        </insert>

        <rollback>
            <delete tableName="Privilege">
                <where>code_privilege IN (
                    'CREATE_CREDIT','VALIDATE_CREDIT','DISBURSE_CREDIT','REJECT_CREDIT',
                    'POST_REGLEMENT','OPEN_COMPTE_EPS','DEPOSIT_EPARGNE','WITHDRAW_EPARGNE',
                    'BANK_OPERATION','MANAGE_CHEQUE',
                    'CREATE_BUDGET','VALIDATE_BUDGET','RECORD_MOVEMENT',
                    'CLOSE_DAY','MANAGE_USERS','VIEW_AUDIT',
                    'VIEW_REPORTS','EXPORT_REPORTS'
                )</where>
            </delete>
        </rollback>
    </changeSet>

    <!-- ================================================================
         P9-007-C : Association ADMIN ↔ tous les privilèges
         ================================================================ -->
    <changeSet id="P9-007-seed-admin-privileges" author="microfina">
        <comment>Grant all privileges to the ADMIN role via RolePrivilege cross join</comment>

        <sql>
INSERT INTO RolePrivilege (id_role, id_privilege)
SELECT r.id, p.id
FROM Role r, Privilege p
WHERE r.code_role = 'ADMIN'
        </sql>

        <rollback>
            <sql>
DELETE rp
FROM RolePrivilege rp
INNER JOIN Role r ON rp.id_role = r.id
WHERE r.code_role = 'ADMIN'
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
