<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P3-006 – PCFRAISPARAMCOMPLEXE
        Complex fee parameter grid for a credit product: defines tiered/stepped
        fee rules based on loan amount, duration bracket, or member category.
        Each row is one cell in the fee grid.

        FK dependencies:
          produitcredit (NUMPRODUIT) – Phase 3
        DDL source of truth: Phase 3 spec – Section 1.
    -->
    <changeSet id="P3-006-create-PCFRAISPARAMCOMPLEXE" author="microfina">

        <createTable tableName="PCFRAISPARAMCOMPLEXE">

            <!-- PK -->
            <column name="IDPCFRAISPARAMCOMPLEXE" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_PCFRAISPARAMCOMPLEXE"
                             nullable="false"/>
            </column>

            <!-- ── Fee identity ───────────────────────────────────── -->
            <!-- Fee type code: COM=Commission, ASS=Assurance, PEN=Penalite… -->
            <column name="CODE_TYPE_FRAIS" type="NVARCHAR(50)">
                <constraints nullable="true"/>
            </column>

            <column name="LIBELLE_FRAIS" type="NVARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Amount bracket ─────────────────────────────────── -->
            <column name="MONTANT_MIN_TRANCHE" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <column name="MONTANT_MAX_TRANCHE" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Duration bracket (months) ─────────────────────── -->
            <column name="DUREE_MIN_TRANCHE" type="INT">
                <constraints nullable="true"/>
            </column>

            <column name="DUREE_MAX_TRANCHE" type="INT">
                <constraints nullable="true"/>
            </column>

            <!-- ── Fee value ──────────────────────────────────────── -->
            <!-- Rate (%) if MODECALCUL = TAUX -->
            <column name="TAUX_FRAIS" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- Fixed amount if MODECALCUL = MONTANT_FIXE -->
            <column name="MONTANT_FRAIS" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- TAUX | MONTANT_FIXE | MAX(TAUX,MONTANT_FIXE) -->
            <column name="MODECALCUL_FRAIS" type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <!-- Minimum fee amount (floor) -->
            <column name="MONTANT_MIN_FRAIS" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- Maximum fee amount (cap) -->
            <column name="MONTANT_MAX_FRAIS" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- ── Collection timing ──────────────────────────────── -->
            <!-- DEBUT=at disbursement, ECHEANCE=per instalment, FIN=at end -->
            <column name="PERIODICITE_PRELEVEMENT" type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <!-- Accounting account for this fee line -->
            <column name="COMPTE_COMPTABLE" type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <!-- 1 = row is active -->
            <column name="ACTIF" type="INT" defaultValueNumeric="1">
                <constraints nullable="true"/>
            </column>

            <!-- Optimistic lock -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <rollback>
            <dropTable tableName="PCFRAISPARAMCOMPLEXE"/>
        </rollback>

    </changeSet>

    <!-- FK → produitcredit -->
    <changeSet id="P3-006-fk-PCFRAISPARAMCOMPLEXE-produitcredit" author="microfina">

        <addColumn tableName="PCFRAISPARAMCOMPLEXE">
            <column name="numproduit" type="NVARCHAR(20)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint
            constraintName           = "FK_PCFRAISPARAMCOMPLEXE_produitcredit"
            baseTableName            = "PCFRAISPARAMCOMPLEXE"
            baseColumnNames          = "numproduit"
            referencedTableName      = "produitcredit"
            referencedColumnNames    = "NUMPRODUIT"
            onDelete                 = "CASCADE"
            onUpdate                 = "CASCADE"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="PCFRAISPARAMCOMPLEXE"
                                      constraintName="FK_PCFRAISPARAMCOMPLEXE_produitcredit"/>
            <dropColumn tableName="PCFRAISPARAMCOMPLEXE" columnName="numproduit"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
