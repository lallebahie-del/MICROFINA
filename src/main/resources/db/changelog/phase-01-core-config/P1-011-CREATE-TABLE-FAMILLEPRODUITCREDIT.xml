<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P1-011-CREATE-TABLE-FAMILLEPRODUITCREDIT" author="microfina">
        <comment>Create FAMILLEPRODUITCREDIT table – credit product family taxonomy</comment>

        <createTable tableName="FAMILLEPRODUITCREDIT">
            <column name="CODEFAMILLEPRODUITCREDIT"  type="NVARCHAR(255)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_FAMILLEPRODUITCREDIT"/>
            </column>
            <column name="nomfamilleProduitCredit"   type="NVARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="VERSION"                   type="INT" defaultValueNumeric="0"/>
        </createTable>

        <rollback>
            <dropTable tableName="FAMILLEPRODUITCREDIT"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
