<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P1-007-CREATE-TABLE-FormeJuridique" author="microfina">
        <comment>Create FormeJuridique table – legal forms (SARL, SA, GIE, etc.) for member classification</comment>

        <createTable tableName="FormeJuridique">
            <column name="CODE"     type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_FormeJuridique"/>
            </column>
            <column name="LIBELLE"  type="NVARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="VERSION"  type="INT" defaultValueNumeric="0"/>
        </createTable>

        <rollback>
            <dropTable tableName="FormeJuridique"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
