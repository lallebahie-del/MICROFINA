<?xml version="1.0" encoding="UTF-8"?>
<!--
    P7-002 — Création de la table DepotEpargne (sous-type JOINED de OperationCaisse)
    Dépendances :
      - OperationCaisse (P7-001) → FK_DepotEpargne_OperationCaisse (PK partagée)
    La colonne id est à la fois PK et FK vers OperationCaisse (héritage JOINED).
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P7-002-create-DepotEpargne" author="microfina">
        <createTable tableName="DepotEpargne">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="PK_DepotEpargne" nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            constraintName="FK_DepotEpargne_OperationCaisse"
            baseTableName="DepotEpargne"
            baseColumnNames="id"
            referencedTableName="OperationCaisse"
            referencedColumnNames="id"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="DepotEpargne"/>
            <dropTable tableName="DepotEpargne"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
