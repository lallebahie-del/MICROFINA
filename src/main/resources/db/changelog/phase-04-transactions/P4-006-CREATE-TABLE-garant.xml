<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P4-006 – garant
        Personal guarantor for a credit loan.
        A guarantor may or may not be a registered member (nummembre nullable).

        FK dependencies:
          Credits  (IDCREDIT)  – P4-001
          membres  (NUM_MEMBRE) – Phase 2 (optional)
        DDL source of truth: Phase 4 spec – Section 11 (garanties).
    -->
    <changeSet id="P4-006-create-garant" author="microfina">

        <createTable tableName="garant">

            <!-- PK -->
            <column name="IDGARANT" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="PK_garant"
                             nullable="false"/>
            </column>

            <!-- ── Guarantor identity ───────────────────────────────── -->
            <column name="NOM_GARANT"    type="NVARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <column name="PRENOM_GARANT" type="NVARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <!-- PP=Personne Physique, PM=Personne Morale, MEMBRE=registered member -->
            <column name="TYPE_GARANT"   type="NVARCHAR(50)">
                <constraints nullable="true"/>
            </column>

            <column name="TELEPHONE"     type="NVARCHAR(30)">
                <constraints nullable="true"/>
            </column>

            <column name="ADRESSE"       type="NVARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <!-- ID document reference -->
            <column name="NUMPIECE_IDENTITE" type="NVARCHAR(50)">
                <constraints nullable="true"/>
            </column>

            <!-- Guarantor's own income / salary (for risk assessment) -->
            <column name="REVENU_MENSUEL" type="DECIMAL(19,4)">
                <constraints nullable="true"/>
            </column>

            <!-- Optimistic lock -->
            <column name="VERSION" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <rollback>
            <dropTable tableName="garant"/>
        </rollback>

    </changeSet>

    <!-- FKs -->
    <changeSet id="P4-006-fk-garant" author="microfina">

        <addColumn tableName="garant">
            <column name="idcredit"   type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <!-- Optional: guarantor is also a member -->
        <addColumn tableName="garant">
            <column name="nummembre"  type="NVARCHAR(25)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint
            constraintName        = "FK_garant_Credits"
            baseTableName         = "garant"
            baseColumnNames       = "idcredit"
            referencedTableName   = "Credits"
            referencedColumnNames = "IDCREDIT"
            onDelete              = "CASCADE"
            onUpdate="NO ACTION"/>

        <addForeignKeyConstraint
            constraintName        = "FK_garant_membres"
            baseTableName         = "garant"
            baseColumnNames       = "nummembre"
            referencedTableName   = "membres"
            referencedColumnNames = "NUM_MEMBRE"
            onDelete              = "SET NULL"
            onUpdate="NO ACTION"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="garant"
                                      constraintName="FK_garant_membres"/>
            <dropForeignKeyConstraint baseTableName="garant"
                                      constraintName="FK_garant_Credits"/>
            <dropColumn tableName="garant" columnName="nummembre"/>
            <dropColumn tableName="garant" columnName="idcredit"/>
        </rollback>

    </changeSet>

</databaseChangeLog>