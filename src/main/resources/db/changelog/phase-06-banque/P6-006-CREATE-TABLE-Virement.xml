<?xml version="1.0" encoding="UTF-8"?>
<!--
    P6-006 — Création de la table Virement (sous-type JOINED de OperationBanque)
    Dépendances :
      - OperationBanque  (P6-005) → FK_Virement_OperationBanque (PK partagée)
      - CompteBanque     (P6-002) → FK_Virement_CompteSource
      - CompteBanque     (P6-002) → FK_Virement_CompteDest
    Types de virement valides : INTRA_BANQUE / INTER_BANQUE
    La colonne id est à la fois PK et FK vers OperationBanque (héritage JOINED).
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P6-006-create-Virement" author="microfina">
        <createTable tableName="Virement">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="PK_Virement" nullable="false"/>
            </column>
            <column name="compte_source_id" type="BIGINT"/>
            <column name="compte_destination_id" type="BIGINT"/>
            <column name="type_virement" type="NVARCHAR(20)" defaultValue="INTRA_BANQUE">
                <constraints nullable="false"/>
            </column>
            <column name="reference_externe" type="NVARCHAR(50)"/>
            <column name="motif" type="NVARCHAR(500)"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="FK_Virement_OperationBanque"
            baseTableName="Virement"
            baseColumnNames="id"
            referencedTableName="OperationBanque"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="FK_Virement_CompteSource"
            baseTableName="Virement"
            baseColumnNames="compte_source_id"
            referencedTableName="CompteBanque"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="FK_Virement_CompteDest"
            baseTableName="Virement"
            baseColumnNames="compte_destination_id"
            referencedTableName="CompteBanque"
            referencedColumnNames="id"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="Virement"/>
            <dropTable tableName="Virement"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
