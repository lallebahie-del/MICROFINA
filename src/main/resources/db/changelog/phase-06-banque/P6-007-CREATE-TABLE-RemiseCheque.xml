<?xml version="1.0" encoding="UTF-8"?>
<!--
    P6-007 — Création de la table RemiseCheque (sous-type JOINED de OperationBanque)
    Dépendances :
      - OperationBanque  (P6-005) → FK_RemiseCheque_OperationBanque (PK partagée)
      - Cheque           (P6-004) → FK_RemiseCheque_Cheque
    La colonne id est à la fois PK et FK vers OperationBanque (héritage JOINED).
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P6-007-create-RemiseCheque" author="microfina">
        <createTable tableName="RemiseCheque">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="PK_RemiseCheque" nullable="false"/>
            </column>
            <column name="cheque_id" type="BIGINT"/>
            <column name="banque_presentatrice" type="NVARCHAR(100)"/>
            <column name="date_valeur" type="DATE"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="FK_RemiseCheque_OperationBanque"
            baseTableName="RemiseCheque"
            baseColumnNames="id"
            referencedTableName="OperationBanque"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="FK_RemiseCheque_Cheque"
            baseTableName="RemiseCheque"
            baseColumnNames="cheque_id"
            referencedTableName="Cheque"
            referencedColumnNames="id"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="RemiseCheque"/>
            <dropTable tableName="RemiseCheque"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
