<?xml version="1.0" encoding="UTF-8"?>
<!--
    P6-003 — Création de la table CarnetCheque
    Dépendances :
      - CompteBanque  (P6-002) → FK_CarnetCheque_CompteBanque
      - membres       (Phase 2) → FK_CarnetCheque_Membres
    Référencée par : Cheque (via FK_Cheque_CarnetCheque)
    Statuts valides : DEMANDE / IMPRIME / REMIS / EPUISE / PERDU / OPPOSITION
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P6-003-create-CarnetCheque" author="microfina">
        <createTable tableName="CarnetCheque">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_CarnetCheque" nullable="false"/>
            </column>
            <column name="numero_carnet" type="NVARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="date_demande" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="date_remise" type="DATE"/>
            <column name="nombre_cheques" type="INT" defaultValueNumeric="25">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="NVARCHAR(20)" defaultValue="DEMANDE">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="compte_banque_id" type="BIGINT"/>
            <column name="num_membre" type="NVARCHAR(25)"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="FK_CarnetCheque_CompteBanque"
            baseTableName="CarnetCheque"
            baseColumnNames="compte_banque_id"
            referencedTableName="CompteBanque"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="FK_CarnetCheque_Membres"
            baseTableName="CarnetCheque"
            baseColumnNames="num_membre"
            referencedTableName="membres"
            referencedColumnNames="NUM_MEMBRE"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="CarnetCheque"/>
            <dropTable tableName="CarnetCheque"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
