<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P2-007 – EPARGNE  (savings movement – SINGLE_TABLE, includes EpargneGroupe subtype)
        Spec p.31-32.  PK = IDEPARGNE (BIGINT autoIncrement).
        DTYPE discriminator: 'Epargne' | 'EpargneGroupe'.
        FKs wired: compteEps → COMPTEEPS, agence → AGENCE.
        Phase-2+ FK (origine, CODE_MANDATAIRE) stored as plain columns.
    -->
    <changeSet id="P2-007-CREATE-TABLE-EPARGNE" author="microfina">
        <comment>Create EPARGNE table – SINGLE_TABLE for Epargne + EpargneGroupe subtypes per spec p.31-32</comment>

        <createTable tableName="EPARGNE">
            <!-- PK: auto-increment numeric -->
            <column name="IDEPARGNE"           type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_EPARGNE"/>
            </column>

            <!-- Discriminator for SINGLE_TABLE inheritance -->
            <column name="DTYPE"               type="NVARCHAR(31)"/>

            <!-- Operation metadata -->
            <column name="DATEVALEUR"          type="DATE"/>
            <column name="DATEOPERATION"       type="DATE"/>
            <column name="CODETYPEOPERATION"   type="NVARCHAR(255)"/>
            <column name="LIBELLEOPERATION"    type="NVARCHAR(255)"/>
            <column name="NUMPIECE"            type="NVARCHAR(255)"/>
            <column name="TIREUR"              type="NVARCHAR(255)"/>
            <column name="MANDATAIRE"          type="NVARCHAR(255)"/>
            <column name="AUTRES"              type="NVARCHAR(255)"/>
            <column name="ENCAISSE"            type="NVARCHAR(255)"/>
            <column name="DETAILOK"            type="INT"/>
            <column name="CODE_GUICHET"        type="NVARCHAR(255)"/>
            <column name="CODE_CHEQUE_CLIENT"  type="NVARCHAR(15)"/>
            <column name="compteeps_old"       type="NVARCHAR(25)"/>
            <column name="compte"              type="NVARCHAR(30)"/>

            <!-- Financial amounts -->
            <column name="MONTANTCREDIT"       type="DECIMAL(19,4)"/>
            <column name="MONTANTDEBIT"        type="DECIMAL(19,4)"/>
            <column name="INTERETCREDIT"       type="DECIMAL(19,4)"/>
            <column name="INTERETDEBIT"        type="DECIMAL(19,4)"/>
            <column name="SOLDEANCIEN"         type="DECIMAL(19,4)"/>
            <column name="SOLDENOUVEAU"        type="DECIMAL(19,4)"/>
            <column name="NOMBREPARTSOCIAL"    type="BIGINT"/>
            <column name="CALCULINTERET"       type="INT"/>

            <!-- Account reference (AN/255 per spec) -->
            <column name="NUMCOMPTE"           type="NVARCHAR(255)"/>

            <!-- User -->
            <column name="utilisateur"         type="NVARCHAR(48)"/>

            <!-- Optimistic lock -->
            <column name="VERSION"             type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- FK columns wired in Phase 2 -->
            <column name="compteEps"           type="NVARCHAR(255)"/>
            <column name="agence"              type="NVARCHAR(25)"/>

            <!-- Phase-2+ FK columns (no constraints yet) -->
            <column name="origine"             type="BIGINT"/>
            <column name="CODE_MANDATAIRE"     type="NVARCHAR(25)"/>
        </createTable>

        <!-- FK to COMPTEEPS -->
        <addForeignKeyConstraint
            baseTableName="EPARGNE"         baseColumnNames="compteEps"
            referencedTableName="COMPTEEPS" referencedColumnNames="NUMCOMPTE"
            constraintName="FK_EPARGNE_COMPTEEPS"/>

        <!-- FK to AGENCE (Phase 1) -->
        <addForeignKeyConstraint
            baseTableName="EPARGNE"         baseColumnNames="agence"
            referencedTableName="AGENCE"    referencedColumnNames="CODE_AGENCE"
            constraintName="FK_EPARGNE_AGENCE"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="EPARGNE"/>
            <dropTable tableName="EPARGNE"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
