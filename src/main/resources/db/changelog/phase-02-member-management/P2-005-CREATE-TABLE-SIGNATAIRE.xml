<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        P2-005 – SIGNATAIRE  (JOINED subtype of TIERS)
        Spec p.63.  PK = CODE_TIERS (FK to TIERS).
        Represents a signatory person for a corporate/enterprise member.
        FKs wired: TIERS (JOINED inheritance),
                   NUMMEMBRE_ENTREPRISE → membres,
                   NUMMEMBRE_PHYSIQUE   → membres.
        Phase-2+ FK columns: CODE_ORGANE – stored as plain column.
    -->
    <changeSet id="P2-005-CREATE-TABLE-SIGNATAIRE" author="microfina">
        <comment>Create SIGNATAIRE table – JOINED subtype of TIERS; signatory persons of enterprise members</comment>

        <createTable tableName="SIGNATAIRE">
            <!-- PK = FK to TIERS (JOINED inheritance) -->
            <column name="CODE_TIERS"             type="NVARCHAR(50)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_SIGNATAIRE"/>
            </column>

            <!-- Flags and codes -->
            <column name="ACTIFGROUPE"            type="NVARCHAR(1)"/>
            <column name="CODEMEMBRE"             type="NVARCHAR(255)"/>
            <column name="NUMERO"                 type="NVARCHAR(255)"/>
            <column name="TITRE"                  type="NVARCHAR(25)"/>
            <column name="num_membre_old"         type="NVARCHAR(25)"/>

            <!-- Identity reference -->
            <column name="IDPERSONNE"             type="NVARCHAR(50)"/>
            <column name="NUMMEMBRE_GROUPEMENT"   type="NVARCHAR(50)"/>

            <!-- Signature flags -->
            <column name="OBLIGATOIRE"            type="INT"/>

            <!-- Blobs (numeric ref) -->
            <column name="photo"                  type="BIGINT"/>
            <column name="signature"              type="BIGINT"/>

            <!-- Optimistic lock -->
            <column name="VERSION"                type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- FK to membres (enterprise side) -->
            <column name="NUMMEMBRE_ENTREPRISE"   type="NVARCHAR(25)"/>
            <!-- FK to membres (physical person side) -->
            <column name="NUMMEMBRE_PHYSIQUE"     type="NVARCHAR(25)"/>

            <!-- Phase-2+ FK column (no constraint yet) -->
            <column name="CODE_ORGANE"            type="NVARCHAR(25)"/>
        </createTable>

        <!-- JOINED inheritance: CODE_TIERS FK to TIERS -->
        <addForeignKeyConstraint
            baseTableName="SIGNATAIRE"      baseColumnNames="CODE_TIERS"
            referencedTableName="TIERS"     referencedColumnNames="CODE_TIERS"
            constraintName="FK_SIGNATAIRE_TIERS"/>

        <!-- FK to membres (enterprise member) -->
        <addForeignKeyConstraint
            baseTableName="SIGNATAIRE"      baseColumnNames="NUMMEMBRE_ENTREPRISE"
            referencedTableName="membres"   referencedColumnNames="NUM_MEMBRE"
            constraintName="FK_SIGNATAIRE_membres_entreprise"/>

        <!-- FK to membres (physical member) -->
        <addForeignKeyConstraint
            baseTableName="SIGNATAIRE"      baseColumnNames="NUMMEMBRE_PHYSIQUE"
            referencedTableName="membres"   referencedColumnNames="NUM_MEMBRE"
            constraintName="FK_SIGNATAIRE_membres_physique"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="SIGNATAIRE"/>
            <dropTable tableName="SIGNATAIRE"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
