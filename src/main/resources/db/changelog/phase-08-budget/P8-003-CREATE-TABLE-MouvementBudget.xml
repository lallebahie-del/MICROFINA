<?xml version="1.0" encoding="UTF-8"?>
<!--
    P8-003 — Création de la table MouvementBudget (écriture budgétaire liée à une ligne)
    Dépendances :
      - LigneBudget  (Phase 8, P8-002) → FK_MouvementBudget_LigneBudget  (ligne_budget_id) NOT NULL
      - comptabilite (Phase 1)          → FK_MouvementBudget_Comptabilite (idcomptabilite)  NOT NULL
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="P8-003-create-MouvementBudget" author="microfina">
        <createTable tableName="MouvementBudget">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_MouvementBudget" nullable="false"/>
            </column>
            <column name="date_mouvement" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="montant" type="DECIMAL(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="libelle" type="NVARCHAR(500)"/>
            <column name="utilisateur" type="NVARCHAR(100)"/>
            <column name="version" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="ligne_budget_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="idcomptabilite" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            constraintName="FK_MouvementBudget_LigneBudget"
            baseTableName="MouvementBudget"
            baseColumnNames="ligne_budget_id"
            referencedTableName="LigneBudget"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            constraintName="FK_MouvementBudget_Comptabilite"
            baseTableName="MouvementBudget"
            baseColumnNames="idcomptabilite"
            referencedTableName="comptabilite"
            referencedColumnNames="IDCOMPTABILITE"/>

        <rollback>
            <dropAllForeignKeyConstraints baseTableName="MouvementBudget"/>
            <dropTable tableName="MouvementBudget"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
